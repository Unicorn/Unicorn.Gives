# Copy to `.env` or `apps/mobile/.env` for local Expo (never commit real secrets).
# Expo only exposes EXPO_PUBLIC_* to the client bundle.

EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_anon_key

# ── Supabase Edge Functions (server-side only) ──
# Put real keys in supabase/.secrets.local (gitignored), then:
#   ./scripts/sync-supabase-ai-secrets.sh
# Or one-off:
#   supabase secrets set GEMINI_API_KEY=your_key --project-ref YOUR_PROJECT_REF
# Optional: OPENAI_API_KEY (body fallback + cover fallback if Gemini image fails)
# Optional: GEMINI_TEXT_MODEL (default gemini-flash-latest), GEMINI_IMAGE_MODEL
#
# Deploy function after code changes:
#   supabase functions deploy admin-ai --project-ref YOUR_PROJECT_REF --use-api
