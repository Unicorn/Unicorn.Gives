---
interface Props {
  class?: string;
  padding?: 'none' | 'sm' | 'md' | 'lg';
}

const { class: className = '', padding = 'md' } = Astro.props;
---

<div class={`container padding-${padding} ${className}`}>
  <slot />
</div>

<style>
  .container {
    max-width: var(--max-width);
    margin: 0 auto;
    width: 100%;
  }

  .padding-none {
    padding: 0;
  }

  .padding-sm {
    padding: 0 1rem;
  }

  .padding-md {
    padding: 0 2rem;
  }

  .padding-lg {
    padding: 0 3rem;
  }

  @media (max-width: 768px) {
    .padding-md {
      padding: 0 1rem;
    }

    .padding-lg {
      padding: 0 1.5rem;
    }
  }
</style>
