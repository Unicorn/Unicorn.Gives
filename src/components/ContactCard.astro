---
interface Props {
  name: string;
  title: string;
  email?: string;
  phone?: string;
  icon?: string;
}

const { name, title, email, phone, icon } = Astro.props;
---

<div class="contact-card">
  {icon && <div class="contact-icon" aria-hidden="true">{icon}</div>}
  <div class="contact-info">
    <h3 class="contact-title">{title}</h3>
    <p class="contact-name">{name}</p>
    {email && (
      <p class="contact-detail">
        <span class="detail-label">Email:</span>
        <a href={`mailto:${email}`}>{email}</a>
      </p>
    )}
    {phone && (
      <p class="contact-detail">
        <span class="detail-label">Phone:</span>
        <a href={`tel:${phone}`}>{phone}</a>
      </p>
    )}
  </div>
</div>

<style>
  .contact-card {
    background: white;
    border: 1px solid #e5e7eb;
    border-radius: 12px;
    padding: 2rem;
    transition: all 0.3s ease;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    height: 100%;
  }

  .contact-card:hover {
    border-color: var(--color-primary);
    box-shadow: 0 8px 24px rgba(99, 97, 173, 0.12);
    transform: translateY(-2px);
  }

  .contact-icon {
    font-size: 2.5rem;
    line-height: 1;
    text-align: center;
  }

  .contact-info {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .contact-title {
    font-size: var(--text-lg);
    font-weight: 700;
    color: var(--color-primary);
    margin: 0;
    line-height: 1.3;
  }

  .contact-name {
    font-size: var(--text-base);
    font-weight: 600;
    color: #1f2937;
    margin: 0;
  }

  .contact-detail {
    font-size: var(--text-sm);
    color: #6b7280;
    margin: 0;
    line-height: 1.6;
  }

  .detail-label {
    font-weight: 600;
    color: #374151;
    margin-right: 0.25rem;
  }

  .contact-detail a {
    color: var(--color-link);
    text-decoration: none;
    transition: color 0.2s ease;
    word-break: break-word;
  }

  .contact-detail a:hover {
    color: var(--color-link-hover);
    text-decoration: underline;
  }

  @media (max-width: 768px) {
    .contact-card {
      padding: 1.5rem;
    }

    .contact-icon {
      font-size: 2rem;
    }
  }
</style>
