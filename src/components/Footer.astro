---
const currentYear = new Date().getFullYear();
---

<footer>
  <div class="footer-top">
    <div class="footer-container">
      <!-- Brand -->
      <div class="footer-col footer-brand">
        <h3>Lincoln Township</h3>
        <p>A Clare County community built on shared values, natural beauty, and neighbors helping neighbors since 1867.</p>
        <div class="footer-social">
          <a href="https://facebook.com" aria-label="Facebook">Facebook</a>
          <a href="https://youtube.com" aria-label="YouTube">YouTube</a>
        </div>
      </div>

      <!-- Contact -->
      <div class="footer-col">
        <h4>Contact</h4>
        <address>
          <p>175 Lake George Ave<br/>PO Box 239<br/>Lake George, MI 48633</p>
          <p><a href="tel:989-588-9841">(989) 588-9841</a></p>
          <p>Mon&ndash;Fri 8:00 AM &ndash; 4:30 PM</p>
        </address>
      </div>

      <!-- Quick Links -->
      <div class="footer-col">
        <h4>Quick Links</h4>
        <ul>
          <li><a href="/board">Board of Trustees</a></li>
          <li><a href="/board-minutes">Meeting Minutes</a></li>
          <li><a href="/permits-forms">Permits & Forms</a></li>
          <li><a href="/foia">FOIA Requests</a></li>
          <li><a href="/subscribe">Subscribe</a></li>
        </ul>
      </div>

      <!-- Community -->
      <div class="footer-col">
        <h4>Community</h4>
        <ul>
          <li><a href="/about-unicorn-gives">Unicorn Gives</a></li>
          <li><a href="/about-the-horn">The Horn</a></li>
          <li><a href="/about-the-mane">The Mane</a></li>
          <li><a href="/events">Events</a></li>
          <li><a href="/news">News</a></li>
        </ul>
      </div>
    </div>
  </div>

  <div class="footer-bottom">
    <div class="footer-container">
      <p>&copy; {currentYear} Lincoln Township, Clare County, Michigan. All rights reserved.</p>
      <p>Lincoln Township is an Equal Opportunity Provider.</p>
      <p>Auxiliary aids or services: <a href="tel:989-588-9841">(989) 588-9841</a> | <a href="mailto:clm@lincolntwp.com">clm@lincolntwp.com</a></p>
      <p class="footer-credit">Powered by <a href={Astro.site?.toString().replace(/\/$/, '') || ''}>unicorn.gives</a></p>
    </div>
  </div>
</footer>

<style>
  footer {
    background-color: var(--color-dark-bg);
    color: rgba(255, 255, 255, 0.85);
    margin-top: 0;
  }

  .footer-container {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 2rem;
  }

  /* ===== Top section with columns ===== */
  .footer-top {
    padding: 4rem 0 3rem;
  }

  .footer-top .footer-container {
    display: grid;
    grid-template-columns: 1.5fr 1fr 1fr 1fr;
    gap: 3rem;
  }

  .footer-brand h3 {
    font-family: var(--font-title);
    font-size: 1.75rem;
    color: white;
    margin-bottom: 0.75rem;
    letter-spacing: 1px;
  }

  .footer-brand p {
    font-size: var(--text-sm);
    line-height: 1.7;
    color: rgba(255, 255, 255, 0.7);
    margin-bottom: 1.25rem;
  }

  .footer-social {
    display: flex;
    gap: 1rem;
  }

  .footer-social a {
    color: rgba(255, 255, 255, 0.6);
    font-size: var(--text-sm);
    font-weight: 500;
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .footer-social a:hover {
    color: white;
    text-decoration: none;
  }

  .footer-col h4 {
    font-family: var(--font-heading);
    font-size: 1rem;
    font-weight: 600;
    color: white;
    margin-bottom: 1rem;
    text-transform: uppercase;
    letter-spacing: 1px;
  }

  .footer-col address {
    font-style: normal;
  }

  .footer-col address p {
    font-size: var(--text-sm);
    line-height: 1.6;
    color: rgba(255, 255, 255, 0.7);
    margin-bottom: 0.5rem;
  }

  .footer-col address a {
    color: rgba(255, 255, 255, 0.8);
    text-decoration: none;
  }

  .footer-col address a:hover {
    color: white;
    text-decoration: underline;
  }

  .footer-col ul {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .footer-col ul li {
    margin-bottom: 0.6rem;
  }

  .footer-col ul a {
    color: rgba(255, 255, 255, 0.7);
    font-size: var(--text-sm);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .footer-col ul a:hover {
    color: white;
    text-decoration: none;
  }

  /* ===== Bottom bar ===== */
  .footer-bottom {
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    padding: 1.5rem 0;
  }

  .footer-bottom .footer-container {
    text-align: center;
  }

  .footer-bottom p {
    font-size: var(--text-xs);
    color: rgba(255, 255, 255, 0.5);
    margin: 0.3rem 0;
  }

  .footer-bottom a {
    color: rgba(255, 255, 255, 0.6);
    text-decoration: none;
  }

  .footer-bottom a:hover {
    color: white;
    text-decoration: underline;
  }

  .footer-credit {
    margin-top: 0.5rem !important;
  }

  .footer-credit a {
    color: var(--color-primary-warm);
  }

  .footer-credit a:hover {
    color: var(--color-accent-gold);
  }

  /* ===== Responsive ===== */
  @media (max-width: 1024px) {
    .footer-top .footer-container {
      grid-template-columns: 1fr 1fr;
      gap: 2.5rem;
    }
  }

  @media (max-width: 640px) {
    .footer-top {
      padding: 3rem 0 2rem;
    }

    .footer-top .footer-container {
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    .footer-container {
      padding: 0 1.25rem;
    }
  }
</style>
