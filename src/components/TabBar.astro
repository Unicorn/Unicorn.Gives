---
import type { MicrositeTab } from '../config/navigation';

interface Props {
  tabs: MicrositeTab[];
  activeTab: string;
  basePath: string;
}

const { tabs, activeTab, basePath } = Astro.props;
---

<nav class="tab-bar" role="tablist" aria-label="Page sections">
  {tabs.map((tab) => {
    const isActive = tab.tabSlug === activeTab;
    return (
      <a
        href={`${basePath}/${tab.tabSlug}`}
        role="tab"
        id={`tab-${tab.tabSlug}`}
        aria-selected={isActive ? 'true' : 'false'}
        aria-controls={`panel-${tab.tabSlug}`}
        class:list={['tab-item', { active: isActive }]}
        data-tab-slug={tab.tabSlug}
      >
        {tab.label}
      </a>
    );
  })}
</nav>

<style>
  .tab-bar {
    display: flex;
    gap: 0;
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 2rem;
    border-bottom: 2px solid var(--color-outline-light);
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
  }

  .tab-bar::-webkit-scrollbar {
    display: none;
  }

  .tab-item {
    display: inline-flex;
    align-items: center;
    padding: 0.875rem 1.25rem;
    font-family: var(--font-heading);
    font-size: var(--text-base);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.03em;
    color: var(--color-on-surface-variant);
    text-decoration: none;
    white-space: nowrap;
    border-bottom: 3px solid transparent;
    margin-bottom: -2px;
    transition: color 0.2s ease, border-color 0.2s ease, background-color 0.2s ease;
  }

  .tab-item:hover {
    color: var(--color-primary);
    background-color: var(--color-surface-dim);
  }

  .tab-item.active {
    color: var(--color-primary);
    font-weight: 600;
    border-bottom-color: var(--color-primary);
  }

  .tab-item:focus-visible {
    outline: 3px solid var(--color-accent);
    outline-offset: -3px;
    border-radius: 4px 4px 0 0;
  }

  @media (max-width: 768px) {
    .tab-bar {
      padding: 0 1rem;
    }

    .tab-item {
      padding: 0.75rem 1rem;
      font-size: var(--text-sm);
    }
  }
</style>
