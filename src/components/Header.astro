---
// Header component for the site
---

<header>
  <div class="container">
    <div class="header-content">
      <a href="/" class="site-title">
        <h1>Unicorn Gives</h1>
      </a>
      <p class="tagline">Lincoln Township Community Hub &bull; Clare County, Michigan</p>
    </div>
  </div>
</header>

<style>
  header {
    background-color: white;
    border-bottom: 4px solid var(--color-primary);
    padding: 2rem 0;
  }

  .container {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 2rem;
  }

  .header-content {
    text-align: center;
  }

  .site-title {
    text-decoration: none;
    color: inherit;
  }

  .site-title:hover {
    text-decoration: none;
  }

  .site-title h1 {
    margin: 0;
    font-family: var(--font-title);
    font-size: var(--text-2xl);
    color: var(--color-primary);
    letter-spacing: 2px;
  }

  .tagline {
    font-family: var(--font-heading);
    color: #666;
    font-size: var(--text-lg);
    margin: 0.5rem 0 0 0;
  }

  @media (max-width: 768px) {
    header {
      padding: 1.5rem 0;
    }

    .container {
      padding: 0 1rem;
    }

    .site-title h1 {
      font-size: 2rem;
    }

    .tagline {
      font-size: var(--text-base);
    }
  }
</style>
