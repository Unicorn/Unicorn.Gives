---
interface Props {
  title: string;
  description?: string;
  icon?: string;
  href?: string;
}

const { title, description, icon, href } = Astro.props;
const Tag = href ? 'a' : 'div';
---

<Tag class="feature-card" href={href}>
  {icon && <div class="card-icon" aria-hidden="true">{icon}</div>}
  <h3 class="card-title">{title}</h3>
  {description && <p class="card-description">{description}</p>}
  {href && <span class="card-arrow">→</span>}
</Tag>

<style>
  .feature-card {
    background: white;
    border: 1px solid #e5e7eb;
    border-radius: 12px;
    padding: 2rem;
    transition: all 0.3s ease;
    display: block;
    text-decoration: none;
    color: inherit;
    position: relative;
  }

  .feature-card:hover {
    border-color: var(--color-primary);
    box-shadow: 0 8px 24px rgba(99, 97, 173, 0.12);
    transform: translateY(-4px);
  }

  .card-icon {
    font-size: 2.5rem;
    margin-bottom: 1rem;
    line-height: 1;
  }

  .card-title {
    font-size: var(--text-lg);
    font-weight: 600;
    color: var(--color-primary);
    margin-bottom: 0.75rem;
    line-height: 1.3;
  }

  .card-description {
    font-size: var(--text-base);
    color: #6b7280;
    line-height: 1.6;
    margin: 0;
  }

  .card-arrow {
    position: absolute;
    top: 1.5rem;
    right: 1.5rem;
    font-size: 1.5rem;
    color: var(--color-primary);
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  a.feature-card:hover .card-arrow {
    opacity: 1;
  }

  @media (max-width: 768px) {
    .feature-card {
      padding: 1.5rem;
    }

    .card-arrow {
      display: none;
    }
  }
</style>
