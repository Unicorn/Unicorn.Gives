---
import BaseLayout from './BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';

interface Contact {
  name: string;
  role: string;
  phone?: string;
  email?: string;
}

interface Form {
  name: string;
  url: string;
  format?: string;
}

interface Props {
  title: string;
  description: string;
  scenario: string;
  category: string;
  jurisdiction?: string;
  contacts?: Contact[];
  forms?: Form[];
  relatedGuides?: { slug: string; title: string; scenario: string }[];
  lastVerified: string;
}

const {
  title,
  description,
  scenario,
  category,
  jurisdiction,
  contacts = [],
  forms = [],
  relatedGuides = [],
  lastVerified,
} = Astro.props;

const categoryLabels: Record<string, string> = {
  property: 'Property & Building',
  taxes: 'Taxes & Assessment',
  safety: 'Safety & Emergency',
  nature: 'Nature & Conservation',
  government: 'Government & Records',
  services: 'Services',
  records: 'Records',
};

const jurisdictionLabels: Record<string, string> = {
  township: 'Lincoln Township',
  county: 'Clare County',
  state: 'State of Michigan',
  federal: 'Federal',
};
---

<BaseLayout title={title} description={description}>
  <Breadcrumbs slug={`help`} pageTitle={title} />
  <article class="guide-page">
    <div class="guide-header">
      <div class="guide-meta">
        <span class="guide-category">{categoryLabels[category] || category}</span>
        {jurisdiction && (
          <span class="guide-jurisdiction">{jurisdictionLabels[jurisdiction] || jurisdiction}</span>
        )}
      </div>
      <h1>{scenario}</h1>
      <p class="guide-description">{description}</p>
    </div>

    <div class="guide-layout">
      <div class="guide-content">
        <slot />
      </div>

      <aside class="guide-sidebar">
        {contacts.length > 0 && (
          <div class="sidebar-card">
            <h3>Who to Contact</h3>
            {contacts.map((contact) => (
              <div class="contact-item">
                <strong>{contact.name}</strong>
                <span class="contact-role">{contact.role}</span>
                {contact.phone && (
                  <a href={`tel:${contact.phone.replace(/[^\d+]/g, '')}`} class="contact-phone">
                    {contact.phone}
                  </a>
                )}
                {contact.email && (
                  <a href={`mailto:${contact.email}`} class="contact-email">
                    {contact.email}
                  </a>
                )}
              </div>
            ))}
          </div>
        )}

        {forms.length > 0 && (
          <div class="sidebar-card">
            <h3>Forms & Downloads</h3>
            {forms.map((form) => (
              <a href={form.url} class="form-link" target="_blank" rel="noopener">
                <span class="form-icon">&#x1f4c4;</span>
                <span>
                  <strong>{form.name}</strong>
                  {form.format && <span class="form-format">{form.format}</span>}
                </span>
              </a>
            ))}
          </div>
        )}

        {relatedGuides.length > 0 && (
          <div class="sidebar-card">
            <h3>Related Guides</h3>
            {relatedGuides.map((guide) => (
              <a href={`/help/${guide.slug}/`} class="related-link">
                {guide.scenario || guide.title}
              </a>
            ))}
          </div>
        )}

        <div class="sidebar-card sidebar-verified">
          <p>Last verified: {new Date(lastVerified).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}</p>
          <p class="verified-note">Information may change. When in doubt, call the contact listed above.</p>
        </div>
      </aside>
    </div>
  </article>
</BaseLayout>

<style>
  .guide-page {
    max-width: 100%;
    background: white;
  }

  .guide-header {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 2rem 2rem 1.5rem;
  }

  .guide-meta {
    display: flex;
    gap: 0.5rem;
    margin-bottom: 1rem;
    flex-wrap: wrap;
  }

  .guide-category {
    display: inline-block;
    background: var(--color-secondary);
    color: white;
    padding: 0.2rem 0.75rem;
    border-radius: 50px;
    font-size: var(--text-xs);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .guide-jurisdiction {
    display: inline-block;
    background: var(--color-surface-dim);
    color: var(--color-on-surface-variant);
    padding: 0.2rem 0.75rem;
    border-radius: 50px;
    font-size: var(--text-xs);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .guide-header h1 {
    font-size: clamp(1.5rem, 3vw, var(--text-2xl));
    color: var(--color-primary);
    margin-bottom: 0.75rem;
    line-height: 1.15;
  }

  .guide-description {
    font-size: var(--text-lg);
    color: var(--color-on-surface-variant);
    line-height: 1.6;
    max-width: 700px;
  }

  .guide-layout {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 2rem 3rem;
    display: grid;
    grid-template-columns: 1fr 300px;
    gap: 2.5rem;
    align-items: start;
    box-sizing: border-box;
  }

  /* Content styles */
  .guide-content {
    line-height: 1.7;
  }

  .guide-content :global(h2) {
    margin-top: 2.5rem;
    margin-bottom: 1rem;
    color: var(--color-primary);
    font-size: 1.35rem;
    padding-bottom: 0.5rem;
    border-bottom: 2px solid var(--color-outline-light);
  }

  .guide-content :global(h2:first-of-type) {
    margin-top: 0;
  }

  .guide-content :global(h3) {
    margin-top: 1.5rem;
    margin-bottom: 0.75rem;
    color: var(--color-primary);
  }

  .guide-content :global(ol) {
    margin: 1.5rem 0;
    padding-left: 1.5rem;
  }

  .guide-content :global(ol li) {
    margin-bottom: 1rem;
    padding-left: 0.5rem;
  }

  .guide-content :global(ul) {
    margin: 1rem 0;
    padding-left: 1.5rem;
  }

  .guide-content :global(li) {
    margin-bottom: 0.5rem;
    line-height: 1.6;
  }

  .guide-content :global(p) {
    margin-bottom: 1.25rem;
  }

  .guide-content :global(strong) {
    color: var(--color-on-surface);
  }

  .guide-content :global(blockquote) {
    border-left: 4px solid var(--color-primary-warm);
    background: var(--color-surface-dim);
    padding: 1rem 1.5rem;
    margin: 1.5rem 0;
    border-radius: 0 8px 8px 0;
  }

  .guide-content :global(blockquote p:last-child) {
    margin-bottom: 0;
  }

  /* Sidebar styles */
  .guide-sidebar {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    position: sticky;
    top: 2rem;
  }

  .sidebar-card {
    background: var(--color-surface-dim);
    border-radius: 12px;
    padding: 1.5rem;
  }

  .sidebar-card h3 {
    font-family: var(--font-heading);
    font-size: var(--text-base);
    font-weight: 700;
    color: var(--color-primary);
    margin-bottom: 1rem;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .contact-item {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
    padding: 0.75rem 0;
    border-bottom: 1px solid var(--color-outline-light);
  }

  .contact-item:last-child {
    border-bottom: none;
    padding-bottom: 0;
  }

  .contact-item:first-child {
    padding-top: 0;
  }

  .contact-item strong {
    color: var(--color-on-surface);
    font-size: var(--text-base);
  }

  .contact-role {
    font-size: var(--text-sm);
    color: var(--color-on-surface-variant);
  }

  .contact-phone,
  .contact-email {
    font-size: var(--text-sm);
    color: var(--color-link);
    text-decoration: none;
    font-weight: 600;
  }

  .contact-phone:hover,
  .contact-email:hover {
    color: var(--color-link-hover);
    text-decoration: underline;
  }

  .form-link {
    display: flex;
    gap: 0.75rem;
    align-items: center;
    padding: 0.65rem 0;
    border-bottom: 1px solid var(--color-outline-light);
    text-decoration: none;
    color: inherit;
    transition: color 0.2s;
  }

  .form-link:last-child {
    border-bottom: none;
  }

  .form-link:hover {
    color: var(--color-link);
  }

  .form-icon {
    font-size: 1.25rem;
    flex-shrink: 0;
  }

  .form-link strong {
    display: block;
    font-size: var(--text-sm);
    color: var(--color-link);
  }

  .form-format {
    display: block;
    font-size: var(--text-xs);
    color: var(--color-on-surface-variant);
  }

  .related-link {
    display: block;
    padding: 0.5rem 0;
    border-bottom: 1px solid var(--color-outline-light);
    text-decoration: none;
    color: var(--color-link);
    font-size: var(--text-sm);
    font-weight: 500;
    transition: color 0.2s;
  }

  .related-link:last-child {
    border-bottom: none;
  }

  .related-link:hover {
    color: var(--color-link-hover);
    text-decoration: underline;
  }

  .sidebar-verified {
    background: transparent;
    padding: 1rem 0 0;
    border-top: 1px solid var(--color-outline-light);
  }

  .sidebar-verified p {
    font-size: var(--text-xs);
    color: var(--color-on-surface-variant);
    margin: 0;
  }

  .verified-note {
    margin-top: 0.25rem !important;
    font-style: italic;
  }

  @media (max-width: 900px) {
    .guide-layout {
      grid-template-columns: 1fr;
      padding: 0 1rem 2rem;
    }

    .guide-header {
      padding: 1.5rem 1rem 1rem;
    }

    .guide-sidebar {
      position: static;
    }
  }
</style>
