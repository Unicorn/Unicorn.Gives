---
import BaseLayout from './BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';

interface Props {
  title: string;
  description: string;
  slug?: string;
}

const { title, description, slug = '' } = Astro.props;
---

<BaseLayout title={title} description={description}>
  <Breadcrumbs slug={slug} pageTitle={title} />
  <article class="content-page">
    <div class="page-header">
      <h1>{title}</h1>
    </div>
    <div class="page-content">
      <slot />
    </div>
  </article>
</BaseLayout>

<style>
  .content-page {
    max-width: 100%;
    margin: 0 auto;
    background: var(--surface-card);
  }

  .page-header {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 3rem 2rem 2rem;
    text-align: center;
  }

  .page-header h1 {
    margin: 0;
    font-size: var(--text-2xl);
    color: var(--text-primary);
  }

  .page-content {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 2rem;
  }

  .page-content :global(h1) {
    margin-top: 0;
    margin-bottom: 2rem;
    padding-bottom: 1rem;
    border-bottom: 3px solid var(--border);
  }

  .page-content :global(h2) {
    margin-top: 3rem;
    margin-bottom: 1.5rem;
    padding-bottom: 0.5rem;
    border-bottom: 2px solid var(--border-light);
  }

  .page-content :global(h2:first-of-type) {
    margin-top: 0;
  }

  .page-content :global(h3) {
    margin-top: 2rem;
    margin-bottom: 1rem;
  }

  .page-content :global(h4) {
    margin-top: 1.5rem;
    margin-bottom: 0.75rem;
  }

  .page-content :global(p) {
    margin-bottom: 1.25rem;
    line-height: 1.7;
  }

  .page-content :global(ul),
  .page-content :global(ol) {
    margin: 1.5rem 0;
    padding-left: 2rem;
  }

  .page-content :global(li) {
    margin-bottom: 0.75rem;
    line-height: 1.6;
  }

  .page-content :global(li > ul),
  .page-content :global(li > ol) {
    margin-top: 0.5rem;
    margin-bottom: 0.5rem;
  }

  .page-content :global(ul li strong:first-child) {
    color: var(--text-primary);
    font-size: 1.05em;
  }

  .page-content :global(a) {
    font-weight: 500;
  }

  .page-content :global(h2 + p),
  .page-content :global(h3 + p) {
    margin-top: 1rem;
  }

  .page-content :global(blockquote) {
    border-left: 4px solid var(--link);
    padding-left: 1.5rem;
    margin: 2rem 0;
    font-style: italic;
    color: var(--text-secondary);
  }

  .page-content :global(code) {
    background-color: var(--code-inline-bg);
    padding: 0.2em 0.4em;
    border-radius: 4px;
    font-size: 0.9em;
  }

  .page-content :global(pre) {
    background-color: var(--code-bg);
    color: var(--code-text);
    padding: 1.5rem;
    border-radius: 8px;
    overflow-x: auto;
    margin: 1.5rem 0;
  }

  .page-content :global(pre code) {
    background-color: transparent;
    padding: 0;
    color: inherit;
  }

  .page-content :global(hr) {
    border: none;
    border-top: 2px solid var(--border-light);
    margin: 3rem 0;
  }

  .page-content :global(table) {
    margin: 2rem 0;
    box-shadow: var(--shadow-sm);
  }

  .page-content :global(strong) {
    font-weight: 600;
  }

  @media (max-width: 768px) {
    .page-header {
      padding: 2rem 1rem 1.5rem;
    }

    .page-header h1 {
      font-size: 2rem;
    }

    .page-content {
      padding: 1.5rem 1rem;
    }

    .page-content :global(h1) {
      font-size: 2rem;
      margin-bottom: 1.5rem;
    }

    .page-content :global(h2) {
      font-size: 1.5rem;
      margin-top: 2rem;
    }

    .page-content :global(ul),
    .page-content :global(ol) {
      padding-left: 1.5rem;
    }
  }
</style>
