---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';

export async function getStaticPaths() {
  const minutes = await getCollection('minutes');
  return minutes.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();

const dateObj = new Date(entry.data.date + 'T12:00:00');
const formattedDate = dateObj.toLocaleDateString('en-US', {
  weekday: 'long',
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const statusLabel = entry.data.status === 'pending' ? 'Pending Approval' :
  entry.data.status === 'draft' ? 'Draft' : 'Approved';
const statusClass = entry.data.status === 'pending' ? 'status-pending' :
  entry.data.status === 'draft' ? 'status-draft' : 'status-approved';

const attendees = entry.data.attendees;
---

<BaseLayout
  title={`${entry.data.title} | Meeting Minutes`}
  description={`${entry.data.meetingType} minutes for ${formattedDate}`}
>
  <Breadcrumbs slug={`minutes/${entry.slug}`} pageTitle={entry.data.title} />
  <article class="minutes-page">
    <div class="minutes-header">
      <div class="minutes-meta">
        <span class="minutes-meeting-type">{entry.data.meetingType}</span>
        <span class={`minutes-status ${statusClass}`}>{statusLabel}</span>
        {entry.data.source && (
          <span class="minutes-source">
            {entry.data.source === 'transcribed' ? 'Transcribed' : entry.data.source === 'pdf' ? 'From PDF' : 'Original'}
          </span>
        )}
      </div>
      <h1>{entry.data.title}</h1>
      <p class="minutes-date">{formattedDate}</p>

      {entry.data.pdfUrl && (
        <a href={entry.data.pdfUrl} class="minutes-pdf-btn" target="_blank" rel="noopener">
          Download Original PDF
        </a>
      )}
    </div>

    {attendees && (attendees.present?.length || attendees.absent?.length || attendees.alsoPresent?.length) && (
      <div class="attendees-section">
        {attendees.present && attendees.present.length > 0 && (
          <div class="attendee-group">
            <h3>Present</h3>
            <ul>
              {attendees.present.map((name: string) => <li>{name}</li>)}
            </ul>
          </div>
        )}
        {attendees.absent && attendees.absent.length > 0 && (
          <div class="attendee-group">
            <h3>Absent</h3>
            <ul>
              {attendees.absent.map((name: string) => <li class="absent">{name}</li>)}
            </ul>
          </div>
        )}
        {attendees.alsoPresent && attendees.alsoPresent.length > 0 && (
          <div class="attendee-group">
            <h3>Also Present</h3>
            <ul>
              {attendees.alsoPresent.map((name: string) => <li>{name}</li>)}
            </ul>
          </div>
        )}
      </div>
    )}

    <div class="minutes-content">
      <Content />
    </div>

    <div class="minutes-footer">
      <a href="/minutes/">&larr; Back to Meeting Minutes</a>
    </div>
  </article>
</BaseLayout>

<style>
  .minutes-page {
    max-width: var(--max-width);
    margin: 0 auto;
    background: white;
  }

  .minutes-header {
    padding: 2rem 2rem 1.5rem;
  }

  .minutes-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 0.75rem;
  }

  .minutes-meeting-type {
    background: var(--color-surface-dim);
    color: var(--color-on-surface-variant);
    padding: 0.2rem 0.65rem;
    border-radius: 4px;
    font-size: var(--text-xs);
    font-weight: 600;
  }

  .minutes-status {
    font-size: 0.7rem;
    font-weight: 700;
    padding: 0.2rem 0.65rem;
    border-radius: 4px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .status-pending { background: #fef3cd; color: #856404; }
  .status-approved { background: #d4edda; color: #155724; }
  .status-draft { background: #e2e3e5; color: #383d41; }

  .minutes-source {
    background: var(--color-surface-dim);
    color: var(--color-on-surface-variant);
    padding: 0.2rem 0.65rem;
    border-radius: 4px;
    font-size: var(--text-xs);
    font-weight: 500;
  }

  .minutes-header h1 {
    font-size: clamp(1.5rem, 3vw, var(--text-2xl));
    color: var(--color-primary);
    margin-bottom: 0.5rem;
  }

  .minutes-date {
    font-size: var(--text-lg);
    color: var(--color-on-surface-variant);
  }

  .minutes-pdf-btn {
    display: inline-block;
    margin-top: 1rem;
    background: var(--color-primary);
    color: white;
    padding: 0.6rem 1.25rem;
    border-radius: 50px;
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: var(--text-sm);
    text-decoration: none;
    transition: all 0.2s ease;
  }

  .minutes-pdf-btn:hover {
    background: var(--color-primary-light);
    transform: translateY(-1px);
    text-decoration: none;
    color: white;
  }

  /* Attendees */
  .attendees-section {
    display: flex;
    gap: 2rem;
    padding: 0 2rem 1rem;
    flex-wrap: wrap;
  }

  .attendee-group h3 {
    font-family: var(--font-heading);
    font-size: var(--text-sm);
    font-weight: 700;
    color: var(--color-primary);
    text-transform: uppercase;
    letter-spacing: 0.5px;
    margin-bottom: 0.5rem;
  }

  .attendee-group ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .attendee-group li {
    font-size: var(--text-sm);
    padding: 0.15rem 0;
    color: var(--color-on-surface);
  }

  .attendee-group li.absent {
    color: var(--color-on-surface-variant);
    text-decoration: line-through;
    opacity: 0.7;
  }

  /* Content */
  .minutes-content {
    padding: 1rem 2rem 2rem;
    line-height: 1.7;
    border-top: 2px solid var(--color-outline-light);
  }

  .minutes-content :global(h2) {
    margin-top: 2.5rem;
    margin-bottom: 1rem;
    color: var(--color-primary);
    font-size: 1.25rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--color-outline-light);
  }

  .minutes-content :global(h2:first-of-type) { margin-top: 1rem; }

  .minutes-content :global(p) { margin-bottom: 1rem; }

  .minutes-content :global(ul),
  .minutes-content :global(ol) {
    margin: 1rem 0;
    padding-left: 1.5rem;
  }

  .minutes-content :global(li) {
    margin-bottom: 0.5rem;
    line-height: 1.6;
  }

  .minutes-content :global(strong) { color: var(--color-on-surface); }

  .minutes-content :global(blockquote) {
    border-left: 4px solid var(--color-primary-warm);
    background: var(--color-surface-dim);
    padding: 1rem 1.5rem;
    margin: 1.5rem 0;
    border-radius: 0 8px 8px 0;
  }

  /* Footer */
  .minutes-footer {
    padding: 1.5rem 2rem 3rem;
    border-top: 2px solid var(--color-outline-light);
  }

  .minutes-footer a {
    color: var(--color-link);
    text-decoration: none;
    font-weight: 500;
  }

  .minutes-footer a:hover {
    text-decoration: underline;
  }

  @media (max-width: 768px) {
    .minutes-header, .minutes-content, .minutes-footer, .attendees-section {
      padding-left: 1rem;
      padding-right: 1rem;
    }

    .attendees-section {
      flex-direction: column;
      gap: 1rem;
    }
  }
</style>
