---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Section from '../../components/Section.astro';
import { getCollection } from 'astro:content';

const allGuides = await getCollection('guides');

const categories = [
  { id: 'property', label: 'Property & Building', icon: '&#x1F3E0;', description: 'Permits, zoning, blight notices, building, land division' },
  { id: 'taxes', label: 'Taxes & Assessment', icon: '&#x1F4B0;', description: 'Property taxes, assessments, exemptions, appeals' },
  { id: 'safety', label: 'Safety & Emergency', icon: '&#x1F6A8;', description: 'Fire, sheriff, burn permits, emergency alerts' },
  { id: 'nature', label: 'Nature & Conservation', icon: '&#x1F333;', description: 'Native plants, forestry, invasive species, soil erosion' },
  { id: 'government', label: 'Government & Records', icon: '&#x1F3DB;', description: 'FOIA, elections, voter registration, public records' },
  { id: 'services', label: 'Services', icon: '&#x1F91D;', description: 'Seniors, transit, veterans, animal control' },
  { id: 'records', label: 'Records', icon: '&#x1F4C2;', description: 'Vital records, land records, court records' },
];

const guidesByCategory = categories.map((cat) => ({
  ...cat,
  guides: allGuides
    .filter((g) => g.data.category === cat.id)
    .sort((a, b) => a.data.title.localeCompare(b.data.title)),
})).filter((cat) => cat.guides.length > 0);
---

<BaseLayout
  title="Help Center | Unicorn Gives"
  description="Find answers to common questions about property, taxes, building, conservation, and government services in Clare County, Michigan"
>
  <section class="help-hero">
    <div class="help-hero-inner">
      <h1>What do you need help with?</h1>
      <p>Find step-by-step answers to your questions about Clare County services, permits, taxes, and more.</p>
    </div>
  </section>

  <Section padding="lg">
    <div class="category-grid">
      {categories.map((cat) => {
        const catGuides = allGuides.filter((g) => g.data.category === cat.id);
        if (catGuides.length === 0) return null;
        return (
          <a href={`#${cat.id}`} class="category-card">
            <span class="category-icon" set:html={cat.icon} />
            <h2>{cat.label}</h2>
            <p>{cat.description}</p>
            <span class="category-count">{catGuides.length} {catGuides.length === 1 ? 'guide' : 'guides'}</span>
          </a>
        );
      })}
    </div>
  </Section>

  {guidesByCategory.map((cat) => (
    <Section padding="md" id={cat.id}>
      <div class="guide-category-section">
        <h2 class="category-heading">
          <span set:html={cat.icon} />
          {cat.label}
        </h2>
        <div class="guide-list">
          {cat.guides.map((guide) => (
            <a href={`/help/${guide.slug}/`} class="guide-card">
              <h3>{guide.data.scenario}</h3>
              <p>{guide.data.description}</p>
              <span class="guide-arrow">&rarr;</span>
            </a>
          ))}
        </div>
      </div>
    </Section>
  ))}
</BaseLayout>

<style>
  .help-hero {
    background: linear-gradient(135deg, var(--nav-bg) 0%, var(--nav-hover) 100%);
    padding: 4rem 2rem;
    text-align: center;
    color: var(--text-inverse);
  }

  .help-hero-inner {
    max-width: 700px;
    margin: 0 auto;
  }

  .help-hero h1 {
    font-family: var(--font-title);
    font-size: clamp(2rem, 4vw, 3rem);
    margin-bottom: 0.75rem;
    color: var(--text-inverse);
    letter-spacing: 1px;
  }

  .help-hero p {
    font-size: var(--text-lg);
    opacity: 0.92;
    line-height: 1.6;
  }

  .category-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
    gap: 1.25rem;
  }

  .category-card {
    background: var(--surface-card);
    border: 1px solid var(--border-light);
    border-radius: 12px;
    padding: 1.75rem;
    text-decoration: none;
    color: inherit;
    transition: all 0.25s ease;
    display: flex;
    flex-direction: column;
  }

  .category-card:hover {
    border-color: var(--text-primary);
    box-shadow: 0 8px 24px var(--shadow-md);
    transform: translateY(-3px);
    text-decoration: none;
  }

  .category-icon {
    font-size: 2rem;
    margin-bottom: 0.75rem;
  }

  .category-card h2 {
    font-family: var(--font-heading);
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--text-primary);
    margin-bottom: 0.5rem;
  }

  .category-card p {
    font-size: var(--text-sm);
    color: var(--text-secondary);
    line-height: 1.5;
    flex: 1;
  }

  .category-count {
    font-size: var(--text-xs);
    color: var(--green-400);
    font-weight: 600;
    margin-top: 0.75rem;
  }

  .category-heading {
    font-family: var(--font-title);
    font-size: var(--text-2xl);
    color: var(--text-primary);
    margin-bottom: 1.5rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    letter-spacing: 1px;
  }

  .guide-list {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
    gap: 1rem;
  }

  .guide-card {
    display: block;
    background: var(--surface-card);
    border: 1px solid var(--border-light);
    border-radius: 10px;
    padding: 1.5rem;
    text-decoration: none;
    color: inherit;
    transition: all 0.2s ease;
    position: relative;
  }

  .guide-card:hover {
    border-color: var(--text-primary);
    box-shadow: 0 4px 12px var(--shadow-md);
    transform: translateY(-2px);
    text-decoration: none;
  }

  .guide-card h3 {
    font-size: var(--text-base);
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: 0.5rem;
    padding-right: 2rem;
    line-height: 1.4;
  }

  .guide-card p {
    font-size: var(--text-sm);
    color: var(--text-secondary);
    line-height: 1.5;
    margin: 0;
  }

  .guide-arrow {
    position: absolute;
    top: 1.25rem;
    right: 1.25rem;
    font-size: 1.25rem;
    color: var(--text-primary);
    opacity: 0;
    transition: opacity 0.2s;
  }

  .guide-card:hover .guide-arrow {
    opacity: 1;
  }

  @media (max-width: 640px) {
    .guide-list {
      grid-template-columns: 1fr;
    }

    .category-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 400px) {
    .category-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
