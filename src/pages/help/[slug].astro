---
import { getCollection } from 'astro:content';
import GuideLayout from '../../layouts/GuideLayout.astro';

export async function getStaticPaths() {
  const guides = await getCollection('guides');
  const allGuides = await getCollection('guides');

  return guides.map((guide) => {
    const relatedGuides = (guide.data.relatedGuides || [])
      .map((slug: string) => {
        const found = allGuides.find((g) => g.slug === slug);
        return found
          ? { slug: found.slug, title: found.data.title, scenario: found.data.scenario }
          : null;
      })
      .filter(Boolean);

    return {
      params: { slug: guide.slug },
      props: { guide, relatedGuides },
    };
  });
}

const { guide, relatedGuides } = Astro.props;
const { Content } = await guide.render();
---

<GuideLayout
  title={guide.data.title}
  description={guide.data.description}
  scenario={guide.data.scenario}
  category={guide.data.category}
  jurisdiction={guide.data.jurisdiction}
  contacts={guide.data.contacts}
  forms={guide.data.forms}
  relatedGuides={relatedGuides}
  lastVerified={guide.data.lastVerified}
>
  <Content />
</GuideLayout>
