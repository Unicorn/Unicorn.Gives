---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { getCollection } from 'astro:content';

const allNews = await getCollection('news');
const sortedNews = allNews.sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());

const categoryLabels: Record<string, string> = {
  'township': 'Township',
  'unicorn-gives': 'Unicorn Gives',
  'the-horn': 'The Horn',
  'the-mane': 'The Mane',
  'community': 'Community',
};
---

<BaseLayout title="News & Updates" description="Latest news and community updates from Lincoln Township, Unicorn Gives, The Horn, and The Mane">
  <Breadcrumbs slug="news" pageTitle="News & Updates" />
  <article class="content-page">
    <div class="page-header">
      <h1>News & Updates</h1>
      <p class="page-subtitle">Stay informed about what's happening in Lincoln Township and across our community.</p>
    </div>
    <div class="page-content">
      {sortedNews.length === 0 ? (
        <p class="no-posts">No news articles yet. Check back soon for community updates.</p>
      ) : (
        <div class="news-list">
          {sortedNews.map((post) => (
            <a href={`/news/${post.slug}/`} class="news-card">
              <div class="news-card-content">
                <div class="news-meta">
                  {post.data.category && (
                    <span class="news-category">{categoryLabels[post.data.category] || post.data.category}</span>
                  )}
                  <time datetime={post.data.date}>
                    {new Date(post.data.date).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
                  </time>
                </div>
                <h2>{post.data.title}</h2>
                <p>{post.data.description}</p>
              </div>
            </a>
          ))}
        </div>
      )}
    </div>
  </article>
</BaseLayout>

<style>
  .content-page {
    max-width: 100%;
    margin: 0 auto;
    background: white;
  }

  .page-header {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 3rem 2rem 2rem;
    text-align: center;
  }

  .page-header h1 {
    margin: 0;
    font-size: var(--text-2xl);
    color: var(--color-primary);
  }

  .page-subtitle {
    color: var(--color-on-surface-variant);
    margin-top: 0.75rem;
    font-size: var(--text-lg);
  }

  .page-content {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 2rem;
  }

  .no-posts {
    text-align: center;
    color: var(--color-on-surface-variant);
    font-size: var(--text-lg);
    padding: 3rem 0;
  }

  .news-list {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .news-card {
    display: block;
    background: var(--color-surface);
    border: 1px solid var(--color-outline-light);
    border-radius: 8px;
    padding: 1.5rem;
    text-decoration: none;
    color: inherit;
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
  }

  .news-card:hover {
    border-color: var(--color-primary);
    box-shadow: 0 2px 8px rgba(91, 27, 0, 0.15);
    text-decoration: none;
  }

  .news-meta {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 0.75rem;
    font-size: var(--text-sm);
    color: var(--color-on-surface-variant);
  }

  .news-category {
    background: var(--color-secondary);
    color: white;
    padding: 0.2rem 0.6rem;
    border-radius: 4px;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .news-card h2 {
    margin: 0 0 0.5rem;
    font-size: 1.3rem;
    color: var(--color-primary);
    border: none;
    padding: 0;
  }

  .news-card p {
    margin: 0;
    color: var(--color-on-surface);
    line-height: 1.6;
  }

  @media (max-width: 768px) {
    .page-header {
      padding: 2rem 1rem 1.5rem;
    }

    .page-content {
      padding: 1.5rem 1rem;
    }
  }
</style>
