---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import ContactCard from '../components/ContactCard.astro';
import ContactGrid from '../components/ContactGrid.astro';
import Section from '../components/Section.astro';
---

<BaseLayout
  title="Board of Trustees - Lincoln Township"
  description="Lincoln Township Board members, meeting schedule, and contact information"
>
  <Breadcrumbs slug="board" pageTitle="Board of Trustees" />

  <article>
    <h1>Board of Trustees</h1>

    <Section padding="md">
      <p class="intro-text">
        The Lincoln Township Board of Trustees governs the township and makes policy decisions for our community.
      </p>

      <ContactGrid title="Board Members" columns={3}>
        <ContactCard
          name="Dennis Zimmerman"
          title="Supervisor"
          email="denniszimm@charter.net"
          phone="989-588-9343"
          icon="👤"
        />
        <ContactCard
          name="Carol Majewski"
          title="Clerk"
          email="clm@lincolntwp.com"
          phone="989-588-9069"
          icon="📋"
        />
        <ContactCard
          name="Maggie Carey"
          title="Treasurer"
          email="mc@lincolntwp.com"
          phone="989-588-2574"
          icon="💰"
        />
        <ContactCard
          name="Jerry Bridges"
          title="Trustee"
          email="Jbridges@toast.net"
          phone="989-588-6212"
          icon="👤"
        />
        <ContactCard
          name="Mike Tobin"
          title="Trustee"
          email="mtobin@lincolntwp.com"
          phone="989-588-2311"
          icon="👤"
        />
      </ContactGrid>
    </Section>

    <Section background="gray" padding="md">
      <div class="info-section">
        <h2>Board Meetings</h2>
        <p>Regular board meetings are held throughout the year. Special meetings are posted at Township Hall at least 18 hours in advance.</p>
        <p><a href="/board-minutes" class="button-link">View Meeting Minutes & Schedule →</a></p>
      </div>
    </Section>

    <Section padding="md">
      <div class="info-grid">
        <div class="info-card">
          <h3>Contact the Board</h3>
          <p>For questions or concerns, please contact the Township Supervisor or attend a board meeting.</p>
        </div>
        <div class="info-card">
          <h3>Accessibility</h3>
          <p>Individuals with disabilities requiring auxiliary aids or services should contact Carol Majewski at <a href="tel:989-588-9069">989-588-9069</a> or <a href="mailto:clm@lincolntwp.com">clm@lincolntwp.com</a>.</p>
        </div>
      </div>
    </Section>
  </article>
</BaseLayout>

<style>
  article {
    max-width: 100%;
  }

  h1 {
    text-align: center;
    margin-bottom: 2rem;
  }

  .intro-text {
    text-align: center;
    font-size: var(--text-lg);
    color: #374151;
    max-width: 800px;
    margin: 0 auto 3rem;
    line-height: 1.6;
  }

  .info-section {
    max-width: 800px;
    margin: 0 auto;
    text-align: center;
  }

  .info-section h2 {
    color: var(--color-primary);
    margin-bottom: 1rem;
  }

  .info-section p {
    margin-bottom: 1rem;
    line-height: 1.6;
  }

  .button-link {
    display: inline-block;
    font-family: var(--font-heading);
    padding: calc(0.667em + 2px) calc(1.333em + 2px);
    border-radius: var(--radius-button);
    background-color: var(--color-primary);
    color: white;
    border: none;
    text-decoration: none;
    cursor: pointer;
    transition: background-color 0.2s ease;
    font-weight: 600;
    margin-top: 1rem;
  }

  .button-link:hover {
    background-color: var(--color-link-hover);
    text-decoration: none;
  }

  .info-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 2rem;
    max-width: 900px;
    margin: 0 auto;
  }

  .info-card {
    background: white;
    border: 1px solid #e5e7eb;
    border-radius: 12px;
    padding: 2rem;
  }

  .info-card h3 {
    color: var(--color-primary);
    font-size: var(--text-lg);
    margin-bottom: 1rem;
  }

  .info-card p {
    color: #374151;
    line-height: 1.6;
    margin: 0;
  }

  .info-card a {
    color: var(--color-link);
    font-weight: 500;
  }

  @media (max-width: 768px) {
    .intro-text {
      font-size: var(--text-base);
      margin-bottom: 2rem;
    }

    .info-grid {
      grid-template-columns: 1fr;
      gap: 1rem;
    }

    .info-card {
      padding: 1.5rem;
    }
  }
</style>
