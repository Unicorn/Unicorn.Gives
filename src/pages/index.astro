---
import BaseLayout from '../layouts/BaseLayout.astro';
import FeatureGrid from '../components/FeatureGrid.astro';
import FeatureCard from '../components/FeatureCard.astro';
import Section from '../components/Section.astro';
import { getCollection } from 'astro:content';
import { categoryColors, eventCategoryColors, eventCategoryLabels, defaultCategoryColor } from '../config/colors';

const allNews = await getCollection('news');
const sortedNews = allNews
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());

const featuredPost = sortedNews.find(p => p.data.featured) || sortedNews[0];
const sideNews = sortedNews.filter(p => p.slug !== featuredPost?.slug).slice(0, 3);

const allEvents = await getCollection('events');
const now = new Date();
const upcomingEvents = allEvents
  .filter((e) => new Date(e.data.date) >= now)
  .sort((a, b) => new Date(a.data.date).getTime() - new Date(b.data.date).getTime())
  .slice(0, 4);

const categoryLabels: Record<string, string> = {
  'township': 'Township',
  'unicorn-gives': 'Unicorn Gives',
  'the-horn': 'The Horn',
  'the-mane': 'The Mane',
  'community': 'Community',
  'ordinance-change': 'Ordinance Change',
  'government-action': 'Government',
  'public-safety': 'Public Safety',
  'public-notice': 'Public Notice',
  'infrastructure': 'Infrastructure',
  'election': 'Election',
};
---

<BaseLayout
  title="Unicorn Gives | Clare County Community Hub"
  description="Your one-stop resource for Clare County, Michigan — get answers to property, tax, building, and government questions. Community events, news, and services without the runaround."
>
  <!-- Hero — Problem Solver -->
  <section class="hero">
    <div class="hero-overlay"></div>
    <div class="hero-inner">
      <span class="hero-badge">Clare County Community Hub</span>
      <h1 class="hero-headline">
        Stop searching.<br/>
        <span class="hero-headline-italic">Start solving.</span>
      </h1>
      <p class="hero-subtitle">
        One place for every question about property, taxes, building, conservation, and government services in Clare County. No runaround. No guessing which website to visit.
      </p>
      <div class="hero-ctas">
        <a href="/help" class="hero-btn hero-btn-solid">Find Answers</a>
        <a href="/contacts" class="hero-btn hero-btn-outline">Contact Directory</a>
      </div>
    </div>
  </section>

  <!-- Problem-Solver Grid -->
  <Section background="gray" padding="lg">
    <div class="bento-section">
      <h2 class="home-section-title">What do you need help with?</h2>
      <p class="home-section-subtitle">Click a topic to find step-by-step answers</p>
      <div class="bento-grid">
        <a href="/help#property" class="bento-card">
          <span class="bento-icon" aria-hidden="true">&#x1F3E0;</span>
          <h3>Property & Building</h3>
          <p>Permits, zoning, blight notices, pole barns, land splits</p>
        </a>
        <a href="/help#taxes" class="bento-card">
          <span class="bento-icon" aria-hidden="true">&#x1F4B0;</span>
          <h3>Taxes & Assessment</h3>
          <p>Pay taxes, appeal assessments, exemptions, forest program</p>
        </a>
        <a href="/help#safety" class="bento-card">
          <span class="bento-icon" aria-hidden="true">&#x1F6A8;</span>
          <h3>Safety & Emergency</h3>
          <p>Burn permits, emergency alerts, sheriff, fire department</p>
        </a>
        <a href="/help#nature" class="bento-card">
          <span class="bento-icon" aria-hidden="true">&#x1F333;</span>
          <h3>Nature & Conservation</h3>
          <p>Native plants, forestry, invasive species, soil erosion</p>
        </a>
        <a href="/help#government" class="bento-card">
          <span class="bento-icon" aria-hidden="true">&#x1F3DB;</span>
          <h3>Government & Records</h3>
          <p>FOIA, elections, voter registration, public records</p>
        </a>
        <a href="/ordinances" class="bento-card">
          <span class="bento-icon" aria-hidden="true">&#x1F4DC;</span>
          <h3>Ordinances</h3>
          <p>Browse all township ordinances with plain-language summaries</p>
        </a>
      </div>
    </div>
  </Section>

  <!-- Upcoming Events -->
  {upcomingEvents.length > 0 && (
    <Section padding="lg">
      <div class="events-section">
        <h2 class="home-section-title">Upcoming Events</h2>
        <p class="home-section-subtitle">Meetings, hearings, and community events</p>
        <div class="events-grid">
          {upcomingEvents.map((event) => {
            const date = new Date(event.data.date);
            const monthShort = date.toLocaleDateString('en-US', { month: 'short' });
            const day = date.getDate();
            return (
              <div class="event-card-home">
                <div class="event-date-home">
                  <span class="event-month-home">{monthShort}</span>
                  <span class="event-day-home">{day}</span>
                </div>
                <div class="event-body-home">
                  <span class="event-tag-home" style={`background: ${eventCategoryColors[event.data.category] || defaultCategoryColor}`}>
                    {eventCategoryLabels[event.data.category] || event.data.category}
                  </span>
                  <h3>{event.data.title}</h3>
                  {event.data.time && <span class="event-time-home">{event.data.time}</span>}
                </div>
              </div>
            );
          })}
        </div>
        <div class="events-cta">
          <a href="/events/">View All Events &rarr;</a>
        </div>
      </div>
    </Section>
  )}

  <!-- News & Updates -->
  {sortedNews.length > 0 && (
    <Section padding="lg" background="gray">
      <div class="news-section">
        <h2 class="home-section-title">News & Updates</h2>
        <p class="home-section-subtitle">What is happening across Clare County</p>
        <div class="news-layout">
          {featuredPost && (
            <a href={`/news/${featuredPost.slug}/`} class="news-featured">
              <div class="news-featured-image">
                {featuredPost.data.image ? (
                  <img src={featuredPost.data.image} alt="" loading="lazy" />
                ) : (
                  <div class="news-featured-placeholder"></div>
                )}
                {featuredPost.data.category && (
                  <span class="news-tag" style={`background: ${categoryColors[featuredPost.data.category] || defaultCategoryColor}`}>
                    {categoryLabels[featuredPost.data.category] || featuredPost.data.category}
                  </span>
                )}
              </div>
              <div class="news-featured-body">
                <time datetime={featuredPost.data.date}>
                  {new Date(featuredPost.data.date).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}
                </time>
                <h3>{featuredPost.data.title}</h3>
                <p>{featuredPost.data.description}</p>
              </div>
            </a>
          )}

          <div class="news-sidebar">
            {sideNews.map((post) => (
              <a href={`/news/${post.slug}/`} class="news-sidebar-item">
                <div class="news-sidebar-thumb">
                  {post.data.image ? (
                    <img src={post.data.image} alt="" loading="lazy" />
                  ) : (
                    <div class="news-thumb-placeholder"></div>
                  )}
                </div>
                <div class="news-sidebar-body">
                  {post.data.category && (
                    <span class="news-tag-sm" style={`background: ${categoryColors[post.data.category] || defaultCategoryColor}`}>
                      {categoryLabels[post.data.category] || post.data.category}
                    </span>
                  )}
                  <h4>{post.data.title}</h4>
                  <time datetime={post.data.date}>
                    {new Date(post.data.date).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
                  </time>
                </div>
              </a>
            ))}
          </div>
        </div>
        <div class="news-cta">
          <a href="/news/">View All News &rarr;</a>
        </div>
      </div>
    </Section>
  )}

  <!-- Quick Access: Government & Services -->
  <Section padding="lg">
    <FeatureGrid title="Government & Services" columns={4}>
      <FeatureCard
        title="Board of Trustees"
        description="Lincoln Township board members and meeting information"
        icon="&#x1F3DB;"
        href="/board"
      />
      <FeatureCard
        title="Meeting Minutes"
        description="Board, planning commission, and ZBA meeting minutes"
        icon="&#x1F4CB;"
        href="/board-minutes"
      />
      <FeatureCard
        title="Contact Directory"
        description="Every official and department across township and county"
        icon="&#x1F4DE;"
        href="/contacts"
      />
      <FeatureCard
        title="Ordinance Library"
        description="All ordinances with plain-language summaries"
        icon="&#x1F4DC;"
        href="/ordinances"
      />
    </FeatureGrid>
  </Section>

  <!-- Our Community -->
  <Section padding="lg" background="gray">
    <FeatureGrid title="Our Community" columns={3}>
      <FeatureCard
        title="Unicorn Gives"
        description="A non-profit dedicated to strengthening our community through events, outreach, and bringing people together"
        icon="&#x1F984;"
        href="/about-unicorn-gives"
      />
      <FeatureCard
        title="The Horn"
        description="Community center and club — events, gatherings, and a place to connect"
        icon="&#x1F4EF;"
        href="/about-the-horn"
      />
      <FeatureCard
        title="The Mane"
        description="Boutique salon — hair, beauty, and self-care services in the heart of the community"
        icon="&#x1F487;"
        href="/about-the-mane"
      />
    </FeatureGrid>
  </Section>

  <!-- Subscribe CTA -->
  <Section padding="md">
    <div class="subscribe-banner">
      <div class="subscribe-content">
        <h2>Stay Connected with Clare County</h2>
        <p>Get community news, meeting reminders, event announcements, and important updates delivered to your inbox.</p>
        <a href="/subscribe" class="subscribe-btn">Subscribe to Updates</a>
      </div>
    </div>
  </Section>

  <!-- Contact -->
  <Section background="gray" padding="lg">
    <div class="contact-section">
      <h2 class="home-section-title">Quick Contacts</h2>
      <div class="contact-grid">
        <div class="contact-card">
          <h3>Township Office</h3>
          <p><strong>Phone:</strong> <a href="tel:989-588-9841">(989) 588-9841</a></p>
          <p>175 Lake George Ave<br/>PO Box 239<br/>Lake George, MI 48633</p>
        </div>
        <div class="contact-card">
          <h3>Clare County</h3>
          <p><strong>Phone:</strong> <a href="tel:989-539-2510">(989) 539-2510</a></p>
          <p>225 W Main St<br/>Harrison, MI 48625</p>
        </div>
        <div class="contact-card">
          <h3>Non-Emergency</h3>
          <p><strong>24/7 Dispatch:</strong> <a href="tel:989-539-1336">(989) 539-1336</a></p>
          <p>Emergency: <strong>911</strong></p>
        </div>
        <div class="contact-card">
          <h3>Conservation District</h3>
          <p><strong>Phone:</strong> <a href="tel:989-539-6401">(989) 539-6401</a></p>
          <p>Native plants, forestry, soil erosion</p>
        </div>
      </div>
      <div class="additional-links">
        <a href="/contacts">Full Directory</a>
        <a href="/help">Help Center</a>
        <a href="/faq">FAQs</a>
        <a href="/foia">FOIA Requests</a>
      </div>
    </div>
  </Section>
</BaseLayout>

<style>
  /* ===== HERO ===== */
  .hero {
    position: relative;
    min-height: 600px;
    display: flex;
    align-items: center;
    background-image: url('/images/hero-sunset.jpg');
    background-size: cover;
    background-position: center;
    overflow: hidden;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: var(--hero-overlay);
    z-index: 1;
  }

  .hero-inner {
    position: relative;
    z-index: 2;
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 4rem 2rem;
    width: 100%;
  }

  .hero-badge {
    display: inline-block;
    background: rgba(255, 255, 255, 0.15);
    backdrop-filter: blur(4px);
    color: var(--hero-text);
    font-family: var(--font-heading);
    font-size: var(--text-sm);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 2px;
    padding: 0.4rem 1rem;
    border-radius: 50px;
    border: 1px solid rgba(255, 255, 255, 0.25);
    margin-bottom: 1.5rem;
  }

  .hero-headline {
    font-family: var(--font-title);
    font-size: clamp(2.8rem, 6vw, 5rem);
    color: var(--hero-text);
    line-height: 1.05;
    margin-bottom: 1.5rem;
    letter-spacing: 2px;
  }

  .hero-headline-italic {
    font-family: var(--font-heading);
    font-style: italic;
    font-weight: 400;
    letter-spacing: 0;
    font-size: 0.75em;
  }

  .hero-subtitle {
    font-size: clamp(1rem, 1.8vw, 1.25rem);
    color: var(--hero-text);
    max-width: 560px;
    line-height: 1.7;
    margin-bottom: 2rem;
  }

  .hero-ctas {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .hero-btn {
    display: inline-block;
    padding: 0.9rem 2rem;
    border-radius: 50px;
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: 1.0625rem;
    text-decoration: none;
    transition: all 0.25s ease;
  }

  .hero-btn-solid {
    background: var(--surface-card);
    color: var(--text-primary);
  }

  .hero-btn-solid:hover {
    background: var(--surface-dim);
    color: var(--text-primary);
    text-decoration: none;
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(0, 0, 0, 0.2);
  }

  .hero-btn-outline {
    background: transparent;
    color: var(--hero-text);
    border: 2px solid rgba(255, 255, 255, 0.7);
  }

  .hero-btn-outline:hover {
    background: rgba(255, 255, 255, 0.1);
    border-color: var(--hero-text);
    color: var(--hero-text);
    text-decoration: none;
    transform: translateY(-2px);
  }

  @media (max-width: 768px) {
    .hero { min-height: 400px; }
    .hero-inner { padding: 3rem 1.5rem; }
    .hero-ctas { flex-direction: column; }
    .hero-btn { text-align: center; }
  }

  /* ===== HOME SECTION TITLES ===== */
  .home-section-title {
    font-size: var(--text-2xl);
    color: var(--text-primary);
    text-align: center;
    margin-bottom: 0.5rem;
    font-weight: 600;
  }

  .home-section-subtitle {
    text-align: center;
    color: var(--text-secondary);
    font-size: var(--text-lg);
    margin-bottom: 3rem;
  }

  /* ===== BENTO GRID ===== */
  .bento-section { text-align: center; }

  .bento-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
  }

  .bento-card {
    background: var(--surface-card);
    border: 1px solid var(--border-light);
    border-radius: 16px;
    padding: 2rem 1.5rem;
    text-align: center;
    text-decoration: none;
    color: inherit;
    transition: all 0.25s ease;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    box-shadow: var(--shadow-sm);
  }

  .bento-card:hover {
    background: var(--nav-bg);
    color: var(--text-inverse);
    border-color: var(--nav-bg);
    transform: translateY(-4px);
    box-shadow: var(--shadow-lg);
    text-decoration: none;
  }

  .bento-card:hover h3,
  .bento-card:hover p { color: var(--text-inverse); }

  .bento-icon {
    font-size: 2.25rem;
    margin-bottom: 0.75rem;
    line-height: 1;
  }

  .bento-card h3 {
    font-family: var(--font-heading);
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: 0.5rem;
    transition: color 0.25s ease;
  }

  .bento-card p {
    font-size: var(--text-sm);
    color: var(--text-secondary);
    line-height: 1.5;
    margin: 0;
    transition: color 0.25s ease;
  }

  @media (max-width: 768px) {
    .bento-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 400px) {
    .bento-grid { grid-template-columns: 1fr; }
  }

  /* ===== UPCOMING EVENTS ===== */
  .events-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1rem;
  }

  .event-card-home {
    display: flex;
    gap: 1rem;
    background: var(--surface-card);
    border: 1px solid var(--border-light);
    border-radius: 10px;
    padding: 1rem;
    align-items: flex-start;
  }

  .event-date-home {
    flex-shrink: 0;
    width: 50px;
    text-align: center;
    background: var(--nav-bg);
    color: var(--text-inverse);
    border-radius: 8px;
    padding: 0.4rem;
    display: flex;
    flex-direction: column;
  }

  .event-month-home {
    font-size: 0.65rem;
    text-transform: uppercase;
    font-weight: 600;
    letter-spacing: 1px;
  }

  .event-day-home {
    font-family: var(--font-title);
    font-size: 1.5rem;
    line-height: 1;
  }

  .event-body-home h3 {
    font-size: var(--text-base);
    font-weight: 600;
    color: var(--text-primary);
    margin: 0.25rem 0 0.15rem;
    line-height: 1.3;
  }

  .event-tag-home {
    display: inline-block;
    color: var(--text-inverse);
    padding: 0.1rem 0.5rem;
    border-radius: 3px;
    font-size: 0.6rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .event-time-home {
    font-size: var(--text-xs);
    color: var(--text-secondary);
  }

  .events-cta {
    text-align: center;
    margin-top: 2rem;
  }

  .events-cta a {
    color: var(--link);
    text-decoration: none;
    font-weight: 600;
    font-size: var(--text-lg);
  }

  .events-cta a:hover {
    color: var(--link-hover);
    text-decoration: underline;
  }

  /* ===== NEWS LAYOUT ===== */
  .news-layout {
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    gap: 2rem;
    align-items: start;
  }

  .news-featured {
    display: block;
    text-decoration: none;
    color: inherit;
    border-radius: 16px;
    overflow: hidden;
    background: var(--surface-card);
    border: 1px solid var(--border-light);
    transition: box-shadow 0.25s ease, transform 0.25s ease;
  }

  .news-featured:hover {
    box-shadow: var(--shadow-lg);
    transform: translateY(-2px);
    text-decoration: none;
  }

  .news-featured-image {
    position: relative;
    aspect-ratio: 16 / 9;
    background: var(--surface-dim);
    overflow: hidden;
  }

  .news-featured-image img { width: 100%; height: 100%; object-fit: cover; }

  .news-featured-placeholder {
    width: 100%;
    height: 100%;
    background: linear-gradient(135deg, var(--surface-dim) 0%, var(--border-light) 100%);
  }

  .news-tag {
    position: absolute;
    top: 1rem;
    left: 1rem;
    color: var(--text-inverse);
    padding: 0.2rem 0.65rem;
    border-radius: 6px;
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .news-featured-body { padding: 1.5rem; }
  .news-featured-body time { font-size: var(--text-sm); color: var(--text-secondary); }
  .news-featured-body h3 { font-size: 1.35rem; color: var(--text-primary); margin: 0.5rem 0 0.75rem; line-height: 1.3; }
  .news-featured-body p { font-size: var(--text-base); color: var(--text-primary); line-height: 1.6; margin: 0; }

  .news-sidebar { display: flex; flex-direction: column; gap: 1.25rem; }

  .news-sidebar-item {
    display: flex;
    gap: 1rem;
    text-decoration: none;
    color: inherit;
    background: var(--surface-card);
    border: 1px solid var(--border-light);
    border-radius: 12px;
    padding: 1rem;
    transition: box-shadow 0.25s ease, transform 0.25s ease;
    align-items: start;
  }

  .news-sidebar-item:hover {
    box-shadow: var(--shadow-md);
    transform: translateY(-2px);
    text-decoration: none;
  }

  .news-sidebar-thumb {
    flex-shrink: 0;
    width: 80px;
    height: 80px;
    border-radius: 8px;
    overflow: hidden;
    background: var(--surface-dim);
  }

  .news-sidebar-thumb img { width: 100%; height: 100%; object-fit: cover; }

  .news-thumb-placeholder {
    width: 100%; height: 100%;
    background: linear-gradient(135deg, var(--surface-dim) 0%, var(--border-light) 100%);
  }

  .news-tag-sm {
    display: inline-block;
    color: var(--text-inverse);
    padding: 0.1rem 0.5rem;
    border-radius: 4px;
    font-size: 0.65rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    margin-bottom: 0.25rem;
  }

  .news-sidebar-body { flex: 1; min-width: 0; }
  .news-sidebar-body h4 { font-size: 1rem; color: var(--text-primary); margin: 0.25rem 0 0.35rem; line-height: 1.3; }
  .news-sidebar-body time { font-size: var(--text-xs); color: var(--text-secondary); }

  .news-cta { text-align: center; margin-top: 2.5rem; }
  .news-cta a { color: var(--link); text-decoration: none; font-weight: 600; font-size: var(--text-lg); }
  .news-cta a:hover { color: var(--link-hover); text-decoration: underline; }

  @media (max-width: 768px) {
    .news-layout { grid-template-columns: 1fr; }
  }

  /* ===== SUBSCRIBE BANNER ===== */
  .subscribe-banner {
    background: var(--nav-hover);
    border-radius: 20px;
    padding: 3.5rem 2.5rem;
    text-align: center;
  }

  .subscribe-content h2 {
    font-family: var(--font-title);
    font-size: clamp(1.8rem, 3vw, 2.5rem);
    color: var(--hero-text);
    margin-bottom: 0.75rem;
    letter-spacing: 1px;
  }

  .subscribe-content p {
    color: var(--hero-text);
    font-size: var(--text-lg);
    max-width: 500px;
    margin: 0 auto 1.5rem;
    line-height: 1.6;
  }

  .subscribe-btn {
    display: inline-block;
    background: var(--surface-card);
    color: var(--text-primary);
    padding: 0.9rem 2.25rem;
    border-radius: 50px;
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: 1.0625rem;
    text-decoration: none;
    transition: all 0.25s ease;
  }

  .subscribe-btn:hover {
    background: var(--surface-dim);
    color: var(--text-primary);
    text-decoration: none;
    transform: translateY(-2px);
    box-shadow: var(--shadow-lg);
  }

  @media (max-width: 768px) {
    .subscribe-banner { padding: 2.5rem 1.5rem; }
  }

  /* ===== CONTACT SECTION ===== */
