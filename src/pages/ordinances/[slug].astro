---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';

export async function getStaticPaths() {
  const ordinances = await getCollection('ordinances');
  return ordinances.map((ord) => ({
    params: { slug: ord.slug },
    props: { ord },
  }));
}

const { ord } = Astro.props;
const { Content } = await ord.render();

const allOrdinances = await getCollection('ordinances');
const sorted = allOrdinances.sort((a, b) => a.data.number - b.data.number);
const currentIndex = sorted.findIndex((o) => o.slug === ord.slug);
const prev = currentIndex > 0 ? sorted[currentIndex - 1] : null;
const next = currentIndex < sorted.length - 1 ? sorted[currentIndex + 1] : null;

const categoryLabels: Record<string, string> = {
  zoning: 'Zoning & Planning',
  'public-safety': 'Public Safety',
  environment: 'Environment & Lakes',
  property: 'Property & Land',
  infrastructure: 'Infrastructure',
  general: 'General',
};
---

<BaseLayout title={`Ord. ${ord.data.number}: ${ord.data.title} | Unicorn Gives`} description={ord.data.description}>
  <Breadcrumbs slug="ordinances" pageTitle={`Ord. ${ord.data.number}: ${ord.data.title}`} />
  <article class="ord-detail">
    <div class="ord-header">
      <div class="ord-meta">
        <span class="ord-number-badge">Ordinance {ord.data.number}</span>
        <span class="ord-category-badge">{categoryLabels[ord.data.category] || ord.data.category}</span>
        <span class="ord-jurisdiction-badge">{ord.data.jurisdiction === 'township' ? 'Lincoln Township' : 'Clare County'}</span>
      </div>
      <h1>{ord.data.title}</h1>
      <p class="ord-description">{ord.data.description}</p>
      {(ord.data.adoptedDate || ord.data.amendedDate) && (
        <div class="ord-dates">
          {ord.data.adoptedDate && <span>Adopted: {new Date(ord.data.adoptedDate).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}</span>}
          {ord.data.amendedDate && <span>Last Amended: {new Date(ord.data.amendedDate).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}</span>}
        </div>
      )}
      {ord.data.pdfUrl && (
        <a href={ord.data.pdfUrl} class="ord-pdf-btn" target="_blank" rel="noopener">
          View Full Ordinance (PDF)
        </a>
      )}
    </div>

    <div class="ord-content">
      <h2>What This Means for Residents</h2>
      <Content />
    </div>

    <nav class="ord-nav">
      {prev && (
        <a href={`/ordinances/${prev.slug}/`} class="ord-nav-link ord-nav-prev">
          <span class="ord-nav-label">&larr; Previous</span>
          <span class="ord-nav-title">Ord. {prev.data.number}: {prev.data.title}</span>
        </a>
      )}
      {next && (
        <a href={`/ordinances/${next.slug}/`} class="ord-nav-link ord-nav-next">
          <span class="ord-nav-label">Next &rarr;</span>
          <span class="ord-nav-title">Ord. {next.data.number}: {next.data.title}</span>
        </a>
      )}
    </nav>

    <div class="ord-back">
      <a href="/ordinances/">&larr; Back to Ordinance Library</a>
    </div>
  </article>
</BaseLayout>

<style>
  .ord-detail {
    max-width: var(--max-width);
    margin: 0 auto;
    background: white;
  }

  .ord-header {
    padding: 2rem 2rem 1.5rem;
  }

  .ord-meta {
    display: flex;
    gap: 0.5rem;
    margin-bottom: 1rem;
    flex-wrap: wrap;
  }

  .ord-number-badge {
    background: var(--color-primary);
    color: white;
    padding: 0.25rem 0.85rem;
    border-radius: 50px;
    font-size: var(--text-xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .ord-category-badge {
    background: var(--color-secondary);
    color: white;
    padding: 0.25rem 0.75rem;
    border-radius: 50px;
    font-size: var(--text-xs);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .ord-jurisdiction-badge {
    background: var(--color-surface-dim);
    color: var(--color-on-surface-variant);
    padding: 0.25rem 0.75rem;
    border-radius: 50px;
    font-size: var(--text-xs);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .ord-header h1 {
    font-size: clamp(1.5rem, 3vw, var(--text-2xl));
    color: var(--color-primary);
    margin-bottom: 0.75rem;
  }

  .ord-description {
    font-size: var(--text-lg);
    color: var(--color-on-surface-variant);
    line-height: 1.6;
    max-width: 700px;
  }

  .ord-dates {
    display: flex;
    gap: 1.5rem;
    margin-top: 1rem;
    flex-wrap: wrap;
  }

  .ord-dates span {
    font-size: var(--text-sm);
    color: var(--color-on-surface-variant);
  }

  .ord-pdf-btn {
    display: inline-block;
    margin-top: 1.25rem;
    background: var(--color-primary);
    color: white;
    padding: 0.7rem 1.5rem;
    border-radius: 50px;
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: var(--text-sm);
    text-decoration: none;
    transition: all 0.2s ease;
  }

  .ord-pdf-btn:hover {
    background: var(--color-primary-light);
    transform: translateY(-1px);
    text-decoration: none;
    color: white;
  }

  .ord-content {
    padding: 0 2rem 2rem;
    line-height: 1.7;
  }

  .ord-content h2 {
    color: var(--color-primary);
    font-size: 1.35rem;
    margin-bottom: 1rem;
    padding-bottom: 0.5rem;
    border-bottom: 2px solid var(--color-outline-light);
  }

  .ord-content :global(p) {
    margin-bottom: 1rem;
  }

  .ord-content :global(ul),
  .ord-content :global(ol) {
    margin: 1rem 0;
    padding-left: 1.5rem;
  }

  .ord-content :global(li) {
    margin-bottom: 0.5rem;
    line-height: 1.6;
  }

  .ord-nav {
    display: flex;
    gap: 1rem;
    padding: 0 2rem;
    margin-top: 2rem;
  }

  .ord-nav-link {
    flex: 1;
    padding: 1rem;
    background: var(--color-surface-dim);
    border-radius: 10px;
    text-decoration: none;
    color: inherit;
    transition: background 0.2s;
  }

  .ord-nav-link:hover {
    background: var(--color-outline-light);
    text-decoration: none;
  }

  .ord-nav-next {
    text-align: right;
  }

  .ord-nav-label {
    display: block;
    font-size: var(--text-xs);
    color: var(--color-on-surface-variant);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    margin-bottom: 0.25rem;
  }

  .ord-nav-title {
    font-size: var(--text-sm);
    color: var(--color-primary);
    font-weight: 500;
  }

  .ord-back {
    padding: 1.5rem 2rem 3rem;
  }

  .ord-back a {
    color: var(--color-link);
    text-decoration: none;
    font-weight: 500;
  }

  .ord-back a:hover {
    text-decoration: underline;
  }

  @media (max-width: 640px) {
    .ord-header, .ord-content, .ord-nav, .ord-back {
      padding-left: 1rem;
      padding-right: 1rem;
    }

    .ord-nav {
      flex-direction: column;
    }

    .ord-nav-next {
      text-align: left;
    }
  }
</style>
