---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Section from '../../components/Section.astro';
import { getCollection } from 'astro:content';

const allOrdinances = await getCollection('ordinances');
const sorted = allOrdinances.sort((a, b) => a.data.number - b.data.number);

const categories = [
  { id: 'property', label: 'Property & Land' },
  { id: 'public-safety', label: 'Public Safety' },
  { id: 'environment', label: 'Environment & Lakes' },
  { id: 'zoning', label: 'Zoning & Planning' },
  { id: 'infrastructure', label: 'Infrastructure' },
  { id: 'general', label: 'General' },
];

const byCategory = categories
  .map((cat) => ({
    ...cat,
    ordinances: sorted.filter((o) => o.data.category === cat.id),
  }))
  .filter((cat) => cat.ordinances.length > 0);
---

<BaseLayout
  title="Ordinance Library | Unicorn Gives"
  description="Browse all Lincoln Township ordinances with plain-language summaries — property, safety, zoning, lakes, and more"
>
  <section class="ord-hero">
    <div class="ord-hero-inner">
      <h1>Ordinance Library</h1>
      <p>Every Lincoln Township ordinance, with plain-language summaries so you know what they actually mean.</p>
    </div>
  </section>

  <Section padding="lg">
    {byCategory.map((cat) => (
      <div class="ord-category">
        <h2 class="category-heading">{cat.label}</h2>
        <div class="ord-list">
          {cat.ordinances.map((ord) => (
            <a href={`/ordinances/${ord.slug}/`} class="ord-card">
              <div class="ord-number">Ord. {ord.data.number}</div>
              <div class="ord-body">
                <h3>{ord.data.title}</h3>
                <p>{ord.data.description}</p>
                <span class="ord-link">Read more &rarr;</span>
              </div>
            </a>
          ))}
        </div>
      </div>
    ))}
  </Section>
</BaseLayout>

<style>
  .ord-hero {
    background: linear-gradient(135deg, var(--nav-bg) 0%, var(--nav-hover) 100%);
    padding: 3.5rem 2rem;
    text-align: center;
    color: var(--text-inverse);
  }

  .ord-hero-inner {
    max-width: 600px;
    margin: 0 auto;
  }

  .ord-hero h1 {
    font-family: var(--font-title);
    font-size: clamp(2rem, 4vw, 3rem);
    color: var(--text-inverse);
    margin-bottom: 0.5rem;
    letter-spacing: 1px;
  }

  .ord-hero p {
    font-size: var(--text-lg);
    opacity: 0.92;
  }

  .ord-category {
    margin-bottom: 3rem;
  }

  .category-heading {
    font-family: var(--font-title);
    font-size: var(--text-2xl);
    color: var(--text-primary);
    margin-bottom: 1.25rem;
    letter-spacing: 1px;
  }

  .ord-list {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .ord-card {
    display: flex;
    gap: 1.25rem;
    background: var(--surface-card);
    border: 1px solid var(--border-light);
    border-radius: 10px;
    padding: 1.25rem 1.5rem;
    align-items: flex-start;
  }

  .ord-number {
    flex-shrink: 0;
    background: var(--surface-dim);
    color: var(--text-primary);
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: var(--text-sm);
    padding: 0.35rem 0.75rem;
    border-radius: 6px;
    white-space: nowrap;
  }

  .ord-body h3 {
    font-size: var(--text-base);
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: 0.35rem;
  }

  .ord-body p {
    font-size: var(--text-sm);
    color: var(--text-secondary);
    line-height: 1.5;
    margin: 0;
  }

  a.ord-card {
    text-decoration: none;
    color: inherit;
    transition: all 0.2s ease;
  }

  a.ord-card:hover {
    border-color: var(--text-primary);
    box-shadow: 0 4px 12px var(--shadow-md);
    transform: translateY(-2px);
    text-decoration: none;
  }

  .ord-link {
    display: inline-block;
    margin-top: 0.5rem;
    font-size: var(--text-sm);
    color: var(--link);
    font-weight: 500;
  }

  @media (max-width: 640px) {
    .ord-card {
      flex-direction: column;
      gap: 0.5rem;
    }
  }
</style>
