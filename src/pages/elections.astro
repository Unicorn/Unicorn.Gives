---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
---

<BaseLayout
  title="Election & Voting Information - Lincoln Township"
  description="Voter registration, absentee ballots, and election information for Lincoln Township residents"
>
  <Breadcrumbs slug="elections" pageTitle="Election & Voting Information" />

  <article class="elections-page">

    <!-- ============ HERO ============ -->
    <section class="hero">
      <div class="hero-grid">
        <div class="hero-content">
          <span class="hero-badge">Election Center</span>
          <h1 class="hero-headline">
            The integrity of <br /><em>your vote</em> is our mission.
          </h1>
          <p class="hero-intro">
            Welcome to the Lincoln Township Election Center. We are dedicated to providing clear, accessible information to ensure every resident can participate confidently in our democratic process.
          </p>
          <div class="hero-actions">
            <a href="https://mvic.sos.state.mi.us/" class="btn btn-primary" target="_blank" rel="noopener">Check Registration Status</a>
            <a href="https://mvic.sos.state.mi.us/" class="btn btn-secondary" target="_blank" rel="noopener">View Sample Ballot</a>
          </div>
        </div>
        <div class="hero-image-wrap">
          <div class="hero-image">
            <img src="/images/elections-hero.jpg" alt="Lincoln Township Hall surrounded by mature trees in autumn with warm sunlight" loading="eager" />
          </div>
          <div class="hero-quote">
            <p class="quote-text">"A citizen's voice is the heartbeat of the township."</p>
            <p class="quote-attr">— Carol Majewski, Township Clerk</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ============ BENTO GRID ============ -->
    <section class="bento">
      <div class="bento-grid">
        <!-- Voter Registration Card -->
        <div class="bento-registration">
          <div class="bento-header">
            <span class="section-icon" aria-hidden="true">&#x2713;</span>
            <h2>Voter Registration</h2>
          </div>
          <p class="bento-body">
            To vote in Lincoln Township, you must be a U.S. citizen, at least 18 years old by Election Day, and a resident of the township for at least 30 days.
          </p>
          <div class="reg-options">
            <div class="reg-option">
              <h4>By Mail or Online</h4>
              <p>Must be completed at least 15 days prior to the election.</p>
              <a href="https://mvic.sos.state.mi.us/" target="_blank" rel="noopener">Register Online &nearr;</a>
            </div>
            <div class="reg-option">
              <h4>In Person</h4>
              <p>Registration is available at the Clerk's Office up to and including Election Day with proof of residency.</p>
              <a href="mailto:clm@lincolntwp.com">Contact Clerk &rarr;</a>
            </div>
          </div>
        </div>

        <!-- Quick Actions Card -->
        <div class="bento-actions">
          <h3>Common Actions</h3>
          <ul class="actions-list">
            <li>
              <span class="action-icon" aria-hidden="true">&#x1F50D;</span>
              <a href="https://mvic.sos.state.mi.us/" target="_blank" rel="noopener">Find my polling place</a>
            </li>
            <li>
              <span class="action-icon" aria-hidden="true">&#x2709;</span>
              <a href="/docs/absentee_ballot_app.pdf">Request ballot by mail</a>
            </li>
            <li>
              <span class="action-icon" aria-hidden="true">&#x1F3E0;</span>
              <a href="https://mvic.sos.state.mi.us/" target="_blank" rel="noopener">Update my address</a>
            </li>
            <li>
              <span class="action-icon" aria-hidden="true">&#x1F4CB;</span>
              <a href="mailto:clm@lincolntwp.com">Become a poll worker</a>
            </li>
          </ul>
          <div class="actions-footer">
            <span class="footer-label">Township Clerk</span>
            <span class="footer-phone">989-588-9069</span>
          </div>
        </div>
      </div>
    </section>

    <!-- ============ ABSENTEE VOTING ============ -->
    <section class="absentee">
      <div class="section-header">
        <span class="section-icon" aria-hidden="true">&#x2709;</span>
        <h2>Absentee Voting</h2>
      </div>

      <div class="absentee-cards">
        <div class="absentee-card">
          <h3>No-Reason Absentee Voting</h3>
          <p>
            All registered voters in Michigan have the right to vote by mail. Due to the passing of Proposal 18-3, anyone is eligible to request an absentee ballot for any reason. Ballots are available starting 40 days before the election.
          </p>
        </div>
        <div class="absentee-card">
          <h3>Returning Your Ballot</h3>
          <p>
            Completed ballots must be received by the Township Clerk's Office or placed in the secure ballot drop box at Lincoln Township Hall by 8:00 PM on Election Day.
          </p>
          <div class="dropbox-note">
            <span aria-hidden="true">&#x1F4CD;</span>
            <span>Drop box at Lincoln Township Hall</span>
          </div>
        </div>
      </div>

      <!-- Deadlines -->
      <div class="deadlines">
        <h3>Important Deadlines</h3>
        <div class="deadline-cards">
          <div class="deadline-card">
            <span class="deadline-date">15 Days Before</span>
            <span class="deadline-label">Online Registration Cutoff</span>
            <p>Registration by mail or online ends. In-person registration still available at the Clerk's Office.</p>
          </div>
          <div class="deadline-card deadline-card--highlight">
            <span class="deadline-date">Friday Before</span>
            <span class="deadline-label">Mail Ballot Deadline</span>
            <p>5:00 PM: Last day to request an absentee ballot be mailed to you.</p>
          </div>
          <div class="deadline-card">
            <span class="deadline-date">Election Day</span>
            <span class="deadline-label">Polls Open</span>
            <p>Polls open 7:00 AM &ndash; 8:00 PM. All absentee ballots must be returned by 8:00 PM.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ============ POLL WORKER CTA ============ -->
    <section class="poll-worker">
      <img src="/images/elections-community.jpg" alt="" class="poll-worker-bg" loading="lazy" aria-hidden="true" />
      <div class="poll-worker-overlay"></div>
      <div class="poll-worker-content">
        <h2>Serve Your Community</h2>
        <p>We are currently seeking election inspectors for upcoming elections. Join our team and be a vital part of the civic process in Lincoln Township.</p>
        <a href="mailto:clm@lincolntwp.com?subject=Poll%20Worker%20Interest" class="btn btn-green">Apply to Work the Polls</a>
      </div>
    </section>

    <!-- ============ RESOURCES ============ -->
    <section class="resources">
      <h2>Additional Resources</h2>
      <div class="resources-grid">
        <a href="https://mvic.sos.state.mi.us/" class="resource-card" target="_blank" rel="noopener">
          <h4>Michigan Voter Information Center</h4>
          <p>Check registration, view sample ballots, and find your polling location.</p>
          <span class="resource-link">mvic.sos.state.mi.us &nearr;</span>
        </a>
        <a href="https://www.michigan.gov/sos" class="resource-card" target="_blank" rel="noopener">
          <h4>Secretary of State</h4>
          <p>Voter registration, election information, and absentee voting details.</p>
          <span class="resource-link">michigan.gov/sos &nearr;</span>
        </a>
        <a href="http://clareclerkrod.com/" class="resource-card" target="_blank" rel="noopener">
          <h4>Clare County Clerk</h4>
          <p>County elections office: voter registration, sample ballots, and election results.</p>
          <span class="resource-link">clareclerkrod.com &nearr;</span>
        </a>
        <div class="resource-card resource-card--contact">
          <h4>Township Clerk</h4>
          <p>Carol Majewski</p>
          <ul>
            <li><a href="tel:989-588-9069">989-588-9069</a></li>
            <li><a href="mailto:clm@lincolntwp.com">clm@lincolntwp.com</a></li>
          </ul>
        </div>
      </div>
    </section>

  </article>
</BaseLayout>

<style>
  /* ===== PAGE CONTAINER ===== */
  .elections-page {
    max-width: 100%;
    background: white;
  }

  .elections-page section {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 2rem;
  }

  /* ===== HERO ===== */
  .hero {
    padding-top: 3rem !important;
    padding-bottom: 5rem !important;
  }

  .hero-grid {
    display: grid;
    grid-template-columns: 7fr 5fr;
    gap: 3rem;
    align-items: center;
  }

  .hero-badge {
    display: inline-block;
    padding: 0.35rem 1rem;
    border-radius: var(--radius-button);
    background-color: var(--color-secondary-light);
    color: var(--color-secondary);
    font-family: var(--font-heading);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.15em;
    font-weight: 600;
    margin-bottom: 1.5rem;
  }

  .hero-headline {
    font-family: var(--font-title);
    font-size: clamp(2.5rem, 5vw, 4rem);
    color: var(--color-on-surface);
    line-height: 1.05;
    letter-spacing: 1px;
    margin-bottom: 1.5rem;
  }

  .hero-headline em {
    font-style: italic;
    color: var(--color-primary);
    font-family: var(--font-heading);
    font-weight: 700;
  }

  .hero-intro {
    font-size: var(--text-lg);
    color: var(--color-on-surface-variant);
    line-height: 1.7;
    margin-bottom: 2rem;
    max-width: 540px;
  }

  .hero-actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .hero-image-wrap {
    position: relative;
  }

  .hero-image {
    aspect-ratio: 4 / 5;
    border-radius: 12px;
    overflow: hidden;
    box-shadow: var(--shadow-deep);
  }

  .hero-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .hero-quote {
    position: absolute;
    bottom: -1.5rem;
    left: -1.5rem;
    padding: 1.25rem;
    background: white;
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.12);
    border-radius: 12px;
    border-left: 4px solid var(--color-secondary);
    max-width: 240px;
  }

  .quote-text {
    font-family: var(--font-heading);
    font-style: italic;
    color: var(--color-primary);
    font-size: 1.15rem;
    line-height: 1.3;
    margin-bottom: 0.5rem;
  }

  .quote-attr {
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    opacity: 0.6;
    margin-bottom: 0;
  }

  /* ===== BUTTONS ===== */
  .btn {
    display: inline-block;
    padding: 0.75rem 2rem;
    border-radius: 6px;
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: var(--text-sm);
    text-decoration: none;
    transition: filter 0.2s ease, background-color 0.2s ease;
    cursor: pointer;
    text-align: center;
  }

  .btn:hover {
    text-decoration: none;
  }

  .btn-primary {
    background: linear-gradient(135deg, var(--color-primary), var(--color-primary-light));
    color: white;
    box-shadow: 0 2px 8px rgba(91, 27, 0, 0.25);
  }

  .btn-primary:hover {
    filter: brightness(1.15);
    color: white;
  }

  .btn-secondary {
    background-color: var(--color-surface-dim);
    color: var(--color-on-surface);
  }

  .btn-secondary:hover {
    background-color: var(--color-outline-light);
    color: var(--color-on-surface);
  }

  .btn-green {
    background-color: var(--color-secondary);
    color: white;
    box-shadow: 0 2px 8px rgba(68, 103, 51, 0.3);
  }

  .btn-green:hover {
    filter: brightness(1.1);
    color: white;
  }

  /* ===== BENTO GRID ===== */
  .bento {
    padding-bottom: 5rem !important;
  }

  .bento-grid {
    display: grid;
    grid-template-columns: 2fr 1fr;
    gap: 2rem;
  }

  .bento-registration {
    background-color: var(--color-surface-container);
    padding: 2.5rem;
    border-radius: 12px;
  }

  .bento-header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 1.5rem;
  }

  .bento-header h2 {
    font-family: var(--font-heading);
    font-size: 1.8rem;
    color: var(--color-on-surface);
    margin: 0;
    border: none;
    padding: 0;
  }

  .section-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2rem;
    height: 2rem;
    font-size: 1.25rem;
    color: var(--color-secondary);
    flex-shrink: 0;
  }

  .bento-body {
    color: var(--color-on-surface-variant);
    margin-bottom: 1.5rem;
  }

  .reg-options {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
  }

  .reg-option h4 {
    font-family: var(--font-heading);
    font-size: var(--text-sm);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-secondary);
    margin-bottom: 0.75rem;
  }

  .reg-option p {
    font-size: var(--text-sm);
    line-height: 1.6;
    margin-bottom: 1rem;
  }

  .reg-option a {
    font-weight: 700;
    font-size: var(--text-sm);
    color: var(--color-primary);
  }

  /* Quick Actions */
  .bento-actions {
    background-color: var(--color-primary);
    color: white;
    padding: 2rem;
    border-radius: 12px;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    box-shadow: var(--shadow-natural);
  }

  .bento-actions h3 {
    font-family: var(--font-heading);
    font-size: 1.5rem;
    color: white;
    margin-bottom: 1.5rem;
  }

  .actions-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .actions-list li {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin: 0;
  }

  .action-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2rem;
    height: 2rem;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.1);
    font-size: 0.85rem;
    flex-shrink: 0;
    transition: background 0.2s ease;
  }

  .actions-list li:hover .action-icon {
    background: rgba(255, 255, 255, 0.2);
  }

  .actions-list a {
    color: white;
    font-size: var(--text-sm);
    font-weight: 500;
    text-decoration: none;
  }

  .actions-list a:hover {
    color: white;
    text-decoration: underline;
  }

  .actions-footer {
    margin-top: 2rem;
    padding-top: 1.25rem;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
  }

  .footer-label {
    display: block;
    font-size: 0.625rem;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    opacity: 0.6;
    margin-bottom: 0.25rem;
  }

  .footer-phone {
    font-weight: 700;
    font-size: var(--text-lg);
  }

  /* ===== ABSENTEE VOTING ===== */
  .absentee {
    padding-bottom: 5rem !important;
  }

  .section-header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 2.5rem;
  }

  .section-header h2 {
    font-family: var(--font-heading);
    font-size: 2.25rem;
    color: var(--color-on-surface);
    margin: 0;
    border: none;
    padding: 0;
  }

  .absentee-cards {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
    margin-bottom: 3rem;
  }

  .absentee-card {
    background-color: var(--color-surface-container);
    padding: 2rem;
    border-radius: 12px;
  }

  .absentee-card h3 {
    font-family: var(--font-heading);
    font-size: 1.4rem;
    color: var(--color-on-surface);
    margin-bottom: 1rem;
  }

  .absentee-card p {
    color: var(--color-on-surface-variant);
    line-height: 1.7;
  }

  .dropbox-note {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-top: 1rem;
    font-weight: 700;
    font-size: var(--text-sm);
    color: var(--color-secondary);
  }

  /* Deadlines */
  .deadlines {
    background-color: var(--color-surface-dim);
    padding: 2.5rem;
    border-radius: 12px;
  }

  .deadlines h3 {
    font-family: var(--font-heading);
    font-size: 1.8rem;
    text-align: center;
    margin-bottom: 2rem;
    color: var(--color-on-surface);
  }

  .deadline-cards {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .deadline-card {
    text-align: center;
    padding: 1.5rem;
    background: white;
    border-radius: 8px;
  }

  .deadline-card--highlight {
    border-bottom: 4px solid var(--color-primary);
  }

  .deadline-date {
    display: block;
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 1.5rem;
    color: var(--color-primary);
    margin-bottom: 0.25rem;
  }

  .deadline-label {
    display: block;
    font-size: 0.625rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--color-on-surface-variant);
    margin-bottom: 0.75rem;
  }

  .deadline-card p {
    font-size: var(--text-xs);
    opacity: 0.7;
    line-height: 1.5;
    margin: 0;
  }

  /* ===== POLL WORKER CTA ===== */
  .poll-worker {
    position: relative;
    border-radius: 16px;
    overflow: hidden;
    height: 20rem;
    display: flex;
    align-items: center;
    margin-bottom: 5rem !important;
    max-width: calc(var(--max-width) - 4rem) !important;
    margin-left: auto !important;
    margin-right: auto !important;
  }

  .poll-worker-bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.3;
  }

  .poll-worker-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to right, var(--color-tertiary), rgba(68, 42, 34, 0.8), transparent);
  }

  .poll-worker-content {
    position: relative;
    z-index: 1;
    padding: 0 3rem;
    max-width: 520px;
  }

  .poll-worker-content h2 {
    font-family: var(--font-heading);
    font-size: 2.25rem;
    color: white;
    margin-bottom: 1rem;
    border: none;
    padding: 0;
  }

  .poll-worker-content p {
    color: #c8b8b0;
    margin-bottom: 1.5rem;
    line-height: 1.6;
  }

  /* ===== RESOURCES ===== */
  .resources {
    padding-bottom: 5rem !important;
  }

  .resources h2 {
    font-family: var(--font-heading);
    font-size: 1.8rem;
    color: var(--color-on-surface);
    margin-bottom: 2rem;
    border: none;
    padding: 0;
  }

  .resources-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.5rem;
  }

  .resource-card {
    background-color: var(--color-surface-container);
    padding: 1.5rem;
    border-radius: 12px;
    text-decoration: none;
    color: var(--color-on-surface);
    transition: box-shadow 0.2s ease, transform 0.2s ease;
    display: flex;
    flex-direction: column;
  }

  .resource-card:hover {
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.1);
    transform: translateY(-2px);
    text-decoration: none;
    color: var(--color-on-surface);
  }

  .resource-card h4 {
    font-family: var(--font-heading);
    font-size: 1.1rem;
    color: var(--color-primary);
    margin-bottom: 0.5rem;
  }

  .resource-card p {
    font-size: var(--text-sm);
    color: var(--color-on-surface-variant);
    line-height: 1.5;
    flex-grow: 1;
    margin-bottom: 0.75rem;
  }

  .resource-link {
    font-size: var(--text-xs);
    font-weight: 600;
    color: var(--color-primary);
  }

  .resource-card--contact {
    background-color: var(--color-primary);
    color: white;
  }

  .resource-card--contact h4 {
    color: white;
  }

  .resource-card--contact p {
    color: rgba(255, 255, 255, 0.85);
  }

  .resource-card--contact ul {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .resource-card--contact li {
    margin-bottom: 0.25rem;
  }

  .resource-card--contact a {
    color: rgba(255, 255, 255, 0.9);
    font-size: var(--text-sm);
    font-weight: 500;
  }

  .resource-card--contact a:hover {
    color: white;
  }

  /* ===== RESPONSIVE ===== */
  @media (max-width: 1024px) {
    .hero-grid {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }

    .hero-image-wrap {
      max-width: 400px;
    }

    .bento-grid {
      grid-template-columns: 1fr;
    }

    .resources-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 768px) {
    .elections-page section {
      padding-left: 1rem;
      padding-right: 1rem;
    }

    .hero {
      padding-top: 2rem !important;
      padding-bottom: 4rem !important;
    }

    .hero-headline {
      font-size: 2.25rem;
    }

    .hero-actions {
      flex-direction: column;
    }

    .hero-actions .btn {
      width: 100%;
    }

    .hero-quote {
      position: relative;
      bottom: auto;
      left: auto;
      margin-top: -2rem;
      margin-left: 1rem;
      margin-right: 1rem;
    }

    .reg-options {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }

    .absentee-cards {
      grid-template-columns: 1fr;
    }

    .deadline-cards {
      grid-template-columns: 1fr;
    }

    .poll-worker {
      height: auto;
      min-height: 20rem;
      border-radius: 12px;
    }

    .poll-worker-content {
      padding: 2rem 1.5rem;
    }

    .poll-worker-content h2 {
      font-size: 1.75rem;
    }

    .resources-grid {
      grid-template-columns: 1fr;
    }

    .section-header h2 {
      font-size: 1.75rem;
    }
  }
</style>
