---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Section from '../../components/Section.astro';
import { getCollection } from 'astro:content';
import { eventCategoryColors, eventCategoryLabels, defaultCategoryColor } from '../../config/colors';

const allEvents = await getCollection('events');
const now = new Date();
const upcoming = allEvents
  .filter((e) => new Date(e.data.date) >= now)
  .sort((a, b) => new Date(a.data.date).getTime() - new Date(b.data.date).getTime());

const past = allEvents
  .filter((e) => new Date(e.data.date) < now)
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .slice(0, 10);

const categoryLabels = eventCategoryLabels;
const categoryColors = eventCategoryColors;
---

<BaseLayout
  title="Events & Calendar | Unicorn Gives"
  description="Upcoming meetings, events, and community activities in Clare County, Michigan"
>
  <section class="events-hero">
    <div class="events-hero-inner">
      <h1>Events & Calendar</h1>
      <p>Meetings, events, and community activities across Clare County.</p>
    </div>
  </section>

  <Section padding="lg">
    <h2 class="section-heading">Upcoming Events</h2>
    {upcoming.length === 0 ? (
      <p class="no-events">No upcoming events scheduled. Check back soon.</p>
    ) : (
      <div class="events-list">
        {upcoming.map((event) => {
          const date = new Date(event.data.date);
          const monthShort = date.toLocaleDateString('en-US', { month: 'short' });
          const day = date.getDate();
          return (
            <div class="event-card">
              <div class="event-date-badge">
                <span class="event-month">{monthShort}</span>
                <span class="event-day">{day}</span>
              </div>
              <div class="event-body">
                <div class="event-meta">
                  <span class="event-tag" style={`background: ${categoryColors[event.data.category] || defaultCategoryColor}`}>
                    {categoryLabels[event.data.category] || event.data.category}
                  </span>
                  {event.data.recurring && <span class="event-recurring">Recurring</span>}
                </div>
                <h3>{event.data.title}</h3>
                <p class="event-details">
                  {event.data.time && <span class="event-time">{event.data.time}</span>}
                  <span class="event-location">{event.data.location}</span>
                </p>
                {event.data.description && <p class="event-description">{event.data.description}</p>}
                {event.data.recurrenceRule && (
                  <p class="event-recurrence">Schedule: {event.data.recurrenceRule}</p>
                )}
              </div>
            </div>
          );
        })}
      </div>
    )}
  </Section>

  {past.length > 0 && (
    <Section padding="md" background="gray">
      <h2 class="section-heading">Recent Past Events</h2>
      <div class="events-list past-events">
        {past.map((event) => {
          const date = new Date(event.data.date);
          const monthShort = date.toLocaleDateString('en-US', { month: 'short' });
          const day = date.getDate();
          return (
            <div class="event-card event-past">
              <div class="event-date-badge">
                <span class="event-month">{monthShort}</span>
                <span class="event-day">{day}</span>
              </div>
              <div class="event-body">
                <h3>{event.data.title}</h3>
                <p class="event-details">
                  {event.data.time && <span class="event-time">{event.data.time}</span>}
                  <span class="event-location">{event.data.location}</span>
                </p>
              </div>
            </div>
          );
        })}
      </div>
    </Section>
  )}
</BaseLayout>

<style>
  .events-hero {
    background: linear-gradient(135deg, var(--nav-bg) 0%, var(--nav-hover) 100%);
    padding: 3.5rem 2rem;
    text-align: center;
    color: var(--text-inverse);
  }

  .events-hero-inner {
    max-width: 600px;
    margin: 0 auto;
  }

  .events-hero h1 {
    font-family: var(--font-title);
    font-size: clamp(2rem, 4vw, 3rem);
    color: var(--text-inverse);
    margin-bottom: 0.5rem;
    letter-spacing: 1px;
  }

  .events-hero p {
    font-size: var(--text-lg);
    opacity: 0.92;
  }

  .section-heading {
    font-family: var(--font-title);
    font-size: var(--text-2xl);
    color: var(--text-primary);
    margin-bottom: 1.5rem;
    letter-spacing: 1px;
  }

  .no-events {
    color: var(--text-secondary);
    font-style: italic;
  }

  .events-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .event-card {
    display: flex;
    gap: 1.25rem;
    background: var(--surface-card);
    border: 1px solid var(--border-light);
    border-radius: 10px;
    padding: 1.25rem;
    align-items: flex-start;
  }

  .event-past {
    opacity: 0.65;
  }

  .event-date-badge {
    flex-shrink: 0;
    width: 60px;
    text-align: center;
    background: var(--nav-bg);
    color: var(--text-inverse);
    border-radius: 8px;
    padding: 0.5rem;
    display: flex;
    flex-direction: column;
  }

  .event-month {
    font-size: var(--text-xs);
    text-transform: uppercase;
    font-weight: 600;
    letter-spacing: 1px;
  }

  .event-day {
    font-family: var(--font-title);
    font-size: 1.75rem;
    line-height: 1;
  }

  .event-meta {
    display: flex;
    gap: 0.5rem;
    margin-bottom: 0.35rem;
    flex-wrap: wrap;
  }

  .event-tag {
    display: inline-block;
    color: var(--text-inverse);
    padding: 0.1rem 0.6rem;
    border-radius: 4px;
    font-size: var(--text-xs);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .event-recurring {
    display: inline-block;
    background: var(--surface-dim);
    color: var(--text-secondary);
    padding: 0.1rem 0.6rem;
    border-radius: 4px;
    font-size: var(--text-xs);
    font-weight: 600;
  }

  .event-body h3 {
    font-size: var(--text-lg);
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: 0.35rem;
  }

  .event-details {
    display: flex;
    gap: 1rem;
    font-size: var(--text-sm);
    color: var(--text-secondary);
    margin: 0;
    flex-wrap: wrap;
  }

  .event-time {
    font-weight: 600;
    color: var(--text-primary);
  }

  .event-description {
    font-size: var(--text-sm);
    color: var(--text-secondary);
    margin: 0.5rem 0 0;
    line-height: 1.5;
  }

  .event-recurrence {
    font-size: var(--text-xs);
    color: var(--text-secondary);
    font-style: italic;
    margin: 0.35rem 0 0;
  }

  @media (max-width: 640px) {
    .event-card {
      flex-direction: column;
      gap: 0.75rem;
    }

    .event-date-badge {
      flex-direction: row;
      width: auto;
      gap: 0.5rem;
      align-items: center;
    }

    .event-day {
      font-size: 1.25rem;
    }
  }
</style>
