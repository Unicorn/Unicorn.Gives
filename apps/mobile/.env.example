# Copy to .env and fill in. Expo public vars are available in the client.

# Required for news, events, partners, etc. (Project Settings → API in Supabase).
# Without these, the app uses a placeholder URL and lists stay empty.
# EXPO_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
# EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Opens when user taps "Subscribe" (no email field) or as fallback
# EXPO_PUBLIC_NEWSLETTER_URL=https://example.com/newsletter

# Optional: URL for email signup. Use literal {email} where the subscriber address should go, e.g.
# https://example.com/subscribe?email={email}
# EXPO_PUBLIC_NEWSLETTER_SUBSCRIBE_URL=
