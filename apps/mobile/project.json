{
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "name": "mobile",
  "projectType": "application",
  "root": "apps/mobile",
  "sourceRoot": "apps/mobile",
  "targets": {
    "start": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm run start",
        "cwd": "apps/mobile"
      }
    },
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm exec tsx scripts/generate-sitemap.ts && pnpm exec expo export --platform web",
        "cwd": "apps/mobile"
      }
    }
  }
}

